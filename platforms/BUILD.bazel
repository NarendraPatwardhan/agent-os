load("@rules_zig//zig:toolchain.bzl", "zig_target_toolchain")

# The target worlds agent-os compiles for, all in one home so a target's world is
# visible from its `platform =`/transition — never a buried "excluded from
# default-members" footnote (VISION §8.1).
package(default_visibility = ["//visibility:public"])

# Native host drivers (hosts/wasmtime, server, the projector). musl so a statically
# linked host binary matches a prebuilt libwasmtime.a (§8.1). This is the .bazelrc
# default platform; wasm targets transition away from it.
platform(
    name = "host_musl",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
        "@rules_zig//zig/platforms/abi:musl",
    ],
)

# Both kernels and every pure-wasm guest compile here: freestanding, no host OS,
# no libc, no WASI (A2/A4/A6). The single most load-bearing target world.
platform(
    name = "wasm32_freestanding",
    constraint_values = [
        "@platforms//cpu:wasm32",
        "@platforms//os:none",
    ],
)

# Zig cross-compile-to-wasm toolchain, selected for the platform above during
# toolchain resolution (registered in MODULE.bazel). Zig cross-compiles from the
# host toolchain, so we only describe the -target.
zig_target_toolchain(
    name = "wasm32_freestanding_target",
    target = "wasm32-freestanding",
)

toolchain(
    name = "wasm32_freestanding_zig_toolchain",
    target_compatible_with = [
        "@platforms//cpu:wasm32",
        "@platforms//os:none",
    ],
    toolchain = ":wasm32_freestanding_target",
    toolchain_type = "@rules_zig//zig/target:toolchain_type",
)

# ---------------------------------------------------------------------------
# Phase-later target worlds, defined with the toolchain that consumes them so the
# path→world mapping stays complete and honest (§8.1):
#   wasm32_unknown — Rust's wasm32-unknown-unknown, for interpreter/ (wasmi as a
#     wasm32 staticlib behind a C ABI; Phase B, kernel/zig only). Same Bazel
#     constraints as wasm32_freestanding; the distinction is the Rust target triple.
#   wasm32_wasi    — WASI preview1, the *input* world for converted C/C++ tools
#     before the wasi-adapter rewrites their imports to `mc` (constraint os:wasi).
# Added alongside rules_rust / the wasi-adapter rule in Phase A.
# ---------------------------------------------------------------------------
