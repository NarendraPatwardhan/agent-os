load("@rules_zig//zig:toolchain.bzl", "zig_target_toolchain")

# The target worlds agent-os compiles for, all in one home so a target's world is
# visible from its `platform =`/transition — never a buried "excluded from
# default-members" footnote (SYSTEMS.md).
package(default_visibility = ["//visibility:public"])

# Native host drivers (hosts/wasmtime, server, the projector). musl so a statically
# linked host binary matches a prebuilt libwasmtime.a. This is the .bazelrc
# default platform; wasm targets transition away from it.
platform(
    name = "host_musl",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
        "@rules_zig//zig/platforms/abi:musl",
    ],
)

# Both kernels and every pure-wasm guest compile here: freestanding, no host OS,
# no libc, no WASI (A2/A4/A6). The single most load-bearing target world.
platform(
    name = "wasm32_freestanding",
    constraint_values = [
        "@platforms//cpu:wasm32",
        "@platforms//os:none",
    ],
)

# Zig cross-compile-to-wasm toolchain, selected for the platform above during
# toolchain resolution (registered in MODULE.bazel). Zig cross-compiles from the
# host toolchain, so we only describe the -target.
zig_target_toolchain(
    name = "wasm32_freestanding_target",
    target = "wasm32-freestanding",
)

toolchain(
    name = "wasm32_freestanding_zig_toolchain",
    target_compatible_with = [
        "@platforms//cpu:wasm32",
        "@platforms//os:none",
    ],
    toolchain = ":wasm32_freestanding_target",
    toolchain_type = "@rules_zig//zig/target:toolchain_type",
)

# ---------------------------------------------------------------------------
# Phase-later target worlds, defined with the toolchain that consumes them so the
# path→world mapping stays complete and honest:
#   wasm32_unknown — Rust's wasm32-unknown-unknown, for interpreter/ (wasmi as a
#     wasm32 staticlib behind a C ABI; Phase B, kernel/zig only). Same Bazel
#     constraints as wasm32_freestanding; the distinction is the Rust target triple.
#   wasm32_unknown — Rust's wasm32-unknown-unknown, for interpreter/ (wasmi as a
#     wasm32 staticlib behind a C ABI; Phase B, kernel/zig only).
# ---------------------------------------------------------------------------

# wasm32_wasi — WASI preview1, the INPUT world for the coreutils boxes and converted
# C/C++ tools, before the //memcontainers/wasi-adapter rewrites their `wasi_snapshot_preview1` imports to `mc`.
# The std uutils/external crates a box links require std, which only exists on a wasi target;
# the box's mc-direct applets (cat) keep their `mc` imports straight through. rules_rust's
# wasm32-wasip1 toolchain (MODULE.bazel extra_target_triples) resolves here via os:wasi.
platform(
    name = "wasm32_wasi",
    constraint_values = [
        "@platforms//cpu:wasm32",
        "@platforms//os:wasi",
    ],
)

# The zig toolchain for wasm32-wasi — the C/C++ domain tools (luau) compile their C++ here so zig's
# wasi-libc/libc++ supplies the runtime (malloc / strtod / snprintf / math), then the //wasi-adapter
# rewrites the syscall imports to mc. It coexists with rules_rust's wasm32-wasip1 toolchain on the
# same os:wasi platform (different toolchain_type), so the coreutils boxes (Rust) and luau (zig c++)
# both resolve here. Registered in MODULE.bazel.
zig_target_toolchain(
    name = "wasm32_wasi_target",
    target = "wasm32-wasi",
)

toolchain(
    name = "wasm32_wasi_zig_toolchain",
    target_compatible_with = [
        "@platforms//cpu:wasm32",
        "@platforms//os:wasi",
    ],
    toolchain = ":wasm32_wasi_target",
    toolchain_type = "@rules_zig//zig/target:toolchain_type",
)

# ---------------------------------------------------------------------------
# Elixir control-plane target worlds (//server/otp_hello), selected by `--config=elixir`.
# rules_erlang's dual-platform model: the HOST platform carries the *_internal constraints
# (→ build OTP + Elixir from source), the TARGET platform carries the version constraints
# (→ select the @erlang_config / @elixir_config toolchains). The constraints come from the
# toolchain extensions in //MODULE.bazel; this is never the repo default (a global erlang
# platform would clobber the wasm/Rust/Zig builds).
# ---------------------------------------------------------------------------
platform(
    name = "erlang_internal_platform",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
        "@erlang_config//:erlang_internal",
        "@elixir_config//:elixir_internal",
    ],
)

platform(
    name = "erlang_linux_26_2_platform",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
        "@erlang_config//:erlang_26_2",
        "@elixir_config//:elixir_1_16",
    ],
)
