WASI compatibility for the uutils `sed` crate (v0.1.1), applied by the //MODULE.bazel
http_archive on top of the crates.io source. Two source changes:

  1. src/sed/compiler.rs — drop the `terminal_size` crate (no TTY under WASI); `output_width`
     returns the default. (This is what lets the lib build for wasm32-wasi without terminal_size.)
  2. src/sed/mod.rs — require `=` for the optional `-i` suffix so `sed -i 'script' file` does not
     consume the script as the backup suffix, and add an after-help note.

Dependency selection (dropping the test-only / TTY crates) is handled by the Bazel BUILD file
(sed.BUILD.bazel), so no Cargo.toml hunk is needed.

--- a/src/sed/compiler.rs
+++ b/src/sed/compiler.rs
@@ -24,7 +24,7 @@
 use std::path::PathBuf;
 use std::rc::Rc;

-use terminal_size::{Width, terminal_size};
+// agent-os: terminal_size removed for WASI — no TTY in WASM (see output_width).
 use uucore::error::{UResult, USimpleError};

 const DEFAULT_OUTPUT_WIDTH: usize = 60;
@@ -996,12 +996,9 @@
 }

 /// Return the width of the command's terminal or a default.
+// agent-os: terminal_size stubbed — WASI has no TTY, always return the default.
 fn output_width() -> usize {
-    if let Some((Width(w), _)) = terminal_size() {
-        w as usize
-    } else {
-        DEFAULT_OUTPUT_WIDTH
-    }
+    DEFAULT_OUTPUT_WIDTH
 }

 /// Compile commands that take a number as an argument.
--- a/src/sed/mod.rs
+++ b/src/sed/mod.rs
@@ -32,6 +32,10 @@

 const ABOUT: &str = "Stream editor for filtering and transforming text";
 const USAGE: &str = "sed [OPTION]... [script] [file]...";
+const AFTER_HELP: &str = "\
+Note: this uutils sed runs as an in-VM guest, so both -h and --help print this
+help. -i edits through the VM filesystem; the e/r/w commands can be disabled
+with --sandbox.";

 #[uucore::main]
 pub fn uumain(args: impl uucore::Args) -> UResult<()> {
@@ -54,6 +58,7 @@
     Command::new(util_name)
         .version(crate_version!())
         .about(ABOUT)
+        .after_help(AFTER_HELP)
         .override_usage(format_usage(USAGE))
         .infer_long_args(true)
         .args([
@@ -91,8 +96,12 @@
             Arg::new("in-place")
                 .short('i')
                 .long("in-place")
-                .help("Edit files in place, making a backup if SUFFIX is supplied.")
+                .help("Edit files in place; back up with -i=SUFFIX / --in-place=SUFFIX.")
+                // agent-os: require `=` for the optional suffix so a bare/separated
+                // `-i` does NOT greedily consume the next arg (the script) as the
+                // backup suffix — i.e. `sed -i 'script' file` works as expected.
                 .num_args(0..=1)
+                .require_equals(true)
                 .default_missing_value(""),
             // Access with .get_one::<u32>("line-length")
             arg!(-l --length <NUM> "Specify the 'l' command line-wrap length.")
