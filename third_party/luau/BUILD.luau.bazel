# build_file for the patched @luau source (http_archive build_file = "//third_party/luau:BUILD.luau.bazel"),
# evaluated in the @luau repo context. It only EXPOSES the upstream source; the actual zig c++ build
# (//third_party/luau/glue:luau / :luau-analyze) lives in the main repo and references these. See
# third_party/luau/PLAN.md.

load("@agent-os//third_party/luau:defs.bzl", "cc_headers")

# The interpreter's translation units: VM (bytecode exec) + Compiler + Ast + Bytecode + Common.
filegroup(
    name = "interp_srcs",
    srcs = glob([
        "VM/src/*.cpp",
        "Compiler/src/*.cpp",
        "Ast/src/*.cpp",
        "Bytecode/src/*.cpp",
        "Common/src/*.cpp",
    ]),
    visibility = ["//visibility:public"],
)

# luau-analyze adds Config + the Analysis type-inference engine (Autocomplete/Fragment excluded —
# editor-only, not needed for --check).
filegroup(
    name = "analysis_srcs",
    srcs = glob(
        [
            "Config/src/*.cpp",
            "Analysis/src/*.cpp",
        ],
        exclude = [
            "Analysis/src/Autocomplete.cpp",
            "Analysis/src/AutocompleteCore.cpp",
            "Analysis/src/FragmentAutocomplete.cpp",
        ],
    ),
    visibility = ["//visibility:public"],
)

# The PUBLIC Lua C API headers ONLY (VM/include: lua.h, lualib.h, luaconf.h — all pure C), exposed
# as a CcInfo (no CC toolchain — see //third_party/luau:defs.bzl). rules_zig's @cImport translates
# every `direct_public_header` of its cdeps, so this MUST exclude the C++-tainted internal headers
# (e.g. Common/include/Luau/TimeTrace.h → <vector>) that translate-c (C-only) can't parse. `includes`
# still lists every dir so the csrcs (compiled by zig c++, which handles C++ fine) resolve their
# internal #includes; the internal header FILES reach the compile via :interp_all_hdrs (extra_srcs).
cc_headers(
    name = "interp_headers",
    hdrs = glob(["VM/include/*.h"]),
    includes = [
        "Ast/include",
        "Ast/src",
        "Bytecode/include",
        "Bytecode/src",
        "Common/include",
        "Common/src",
        "Compiler/include",
        "Compiler/src",
        "VM/include",
        "VM/src",
    ],
    visibility = ["//visibility:public"],
)

# ALL interpreter headers (public + internal), as plain files for the csrcs compile (extra_srcs).
# These are NOT a cdep — they must not become @cImport `direct_public_headers`.
filegroup(
    name = "interp_all_hdrs",
    srcs = glob([
        "VM/**/*.h",
        "Compiler/**/*.h",
        "Ast/**/*.h",
        "Bytecode/**/*.h",
        "Common/**/*.h",
    ]),
    visibility = ["//visibility:public"],
)

# Config + Analysis headers for luau-analyze (the build also deps :interp_headers + force-includes
# analysis_eh_shim.h via copts).
cc_headers(
    name = "analysis_headers",
    hdrs = glob([
        "Config/include/**/*.h",
        "Analysis/include/**/*.h",
        "Analysis/src/*.h",
    ]),
    includes = [
        "Analysis/include",
        "Analysis/src",
        "Config/include",
    ],
    visibility = ["//visibility:public"],
)
