load("@bazel_skylib//rules:build_test.bzl", "build_test")
load("@rules_zig//zig:defs.bzl", "zig_library")

# The Luau glue, written in ZIG (the C/C++ → Zig rewrite, VISION §0.2). The patched upstream Luau
# (C++, fetched by the @luau http_archive) links against this. `trap` + the `mc` syscall shim are
# self-contained (no Lua C API) and compile standalone — the trap foundation. The bindings
# (sys/json/hash/re/encoding/deflate + the stdlib loader + the entry — Phase 2 cont.) @cImport
# Luau's Lua C API from @luau and land here too. The C/C++ headers (trap.h, error_channel.h) are
# #included by the patched Luau source. See third_party/luau/PLAN.md.

# trap + mc — the kernel-trap-unwind primitives (mc_protected_call / mc_raise / __mc_pcall_run) over
# the mc_sys_pcall / mc_sys_set_throw imports. No Lua C API, so this compiles standalone (the
# foundation's compile-check). Built for wasm32-wasi (the luau target world).
zig_library(
    name = "trap",
    main = "trap.zig",
    srcs = ["mc.zig"],
    visibility = ["//visibility:public"],
)

# Compile-gate the foundation (matches the contracts' zig_library + build_test): the validation
# action compiles trap.zig + mc.zig, so an invalid edit fails `bazel test //...`. The wasm-specific
# link (extern "mc" resolving to the kernel's syscalls) is validated by the Phase-4 luau binary.
build_test(
    name = "trap_build_test",
    targets = [":trap"],
)

# Headers #included by the patched Luau source: trap.h (ldo.cpp), error_channel.h (Parser.cpp +
# Compiler.cpp). Exported so the @luau build can put this dir on its include path.
exports_files([
    "trap.h",
    "error_channel.h",
])
