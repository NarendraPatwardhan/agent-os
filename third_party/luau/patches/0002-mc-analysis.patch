diff --git a/Analysis/src/TypedAllocator.cpp b/Analysis/src/TypedAllocator.cpp
index 5fb1020..c70bf8f 100644
--- a/Analysis/src/TypedAllocator.cpp
+++ b/Analysis/src/TypedAllocator.cpp
@@ -13,6 +13,11 @@
 #include <windows.h>
 
 const size_t kPageSize = 4096;
+#elif defined(__wasi__)
+// mc PATCH: wasm/wasi has no mmap/mprotect arena. pagedAllocate uses operator new
+// by default (DebugLuauFreezeArena is off), so the paged path below is compiled but
+// never taken; give it a fixed page size + malloc/no-op fallbacks.
+const size_t kPageSize = 65536;
 #else
 #include <sys/mman.h>
 #include <unistd.h>
@@ -51,6 +56,8 @@ void* pagedAllocate(size_t size)
     return _aligned_malloc(size, kPageSize);
 #elif defined(__FreeBSD__)
     return aligned_alloc(kPageSize, size);
+#elif defined(__wasi__)
+    return malloc(pageAlign(size)); // mc PATCH: no mmap on wasi (path is unused)
 #else
     return mmap(nullptr, pageAlign(size), PROT_READ | PROT_WRITE, MAP_PRIVATE | MAP_ANON, -1, 0);
 #endif
@@ -66,6 +73,9 @@ void pagedDeallocate(void* ptr, size_t size)
     _aligned_free(ptr);
 #elif defined(__FreeBSD__)
     free(ptr);
+#elif defined(__wasi__)
+    (void)size; // mc PATCH: malloc/free pairing (no munmap on wasi)
+    free(ptr);
 #else
     int rc = munmap(ptr, size);
     LUAU_ASSERT(rc == 0);
@@ -81,6 +91,8 @@ void pagedFreeze(void* ptr, size_t size)
     DWORD oldProtect;
     BOOL rc = VirtualProtect(ptr, pageAlign(size), PAGE_READONLY, &oldProtect);
     LUAU_ASSERT(rc);
+#elif defined(__wasi__)
+    (void)ptr, (void)size; // mc PATCH: no mprotect on wasi (freeze is a debug-only no-op)
 #else
     int rc = mprotect(ptr, pageAlign(size), PROT_READ);
     LUAU_ASSERT(rc == 0);
@@ -96,6 +108,8 @@ void pagedUnfreeze(void* ptr, size_t size)
     DWORD oldProtect;
     BOOL rc = VirtualProtect(ptr, pageAlign(size), PAGE_READWRITE, &oldProtect);
     LUAU_ASSERT(rc);
+#elif defined(__wasi__)
+    (void)ptr, (void)size; // mc PATCH: no mprotect on wasi (unfreeze is a debug-only no-op)
 #else
     int rc = mprotect(ptr, pageAlign(size), PROT_READ | PROT_WRITE);
     LUAU_ASSERT(rc == 0);
