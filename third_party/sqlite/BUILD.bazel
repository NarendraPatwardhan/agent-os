# sqlite as a guest — fetch upstream, patch in place (SYSTEMS.md, B3; SYSTEMS.md). The SQLite
# amalgamation enters via http_archive(name = "sqlite", urls, sha256) in MODULE.bazel; ONLY our deltas
# live in-tree:
#   glue/                — the Zig serve loop + protocol + the close() shim, compiled by `zig cc`.
#   BUILD.sqlite.bazel   — the build_file http_archive applies to the extracted source.
# 3.51.0 has native SQLITE_WASI support, so there are no source patches — just the compile defines in
# glue/BUILD.bazel. The build stamps mc_tier / mc_budget / mc_service so /bin/sqlite is both a one-shot
# CLI and a resident service from ONE binary.

# Exported so http_archive(build_file = "//third_party/sqlite:BUILD.sqlite.bazel") can apply it to the
# extracted @sqlite source.
exports_files(["BUILD.sqlite.bazel"])
