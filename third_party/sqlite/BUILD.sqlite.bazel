# @sqlite — the SQLite amalgamation (3.51.0, public domain), fetched by MODULE.bazel from sqlite.org
# (SERVICES.md §3.2: fetch upstream, never vendor). Evaluated in the @sqlite repo context. 3.51.0 ships
# native SQLITE_WASI support, so there are no patches — the wasm32-wasi build defines live in
# //memcontainers/programs/sqlite/glue. This exposes exactly what the old vendored copy did (sqlite3.c, sqlite3.h,
# and the `incs` header target), so the glue is a one-line-per-dep repoint. The Zig glue @cImports
# sqlite3.h and links sqlite3.c as a csrc.
load("@agent-os//bazel:mc_program.bzl", "cc_headers")

exports_files(["sqlite3.c", "sqlite3.h"])

# Puts this dir on the -I path so the glue's `@cImport "sqlite3.h"` (and sqlite3.c's own #include)
# resolves. sqlite3.h is plain C, so it can be a direct public header.
cc_headers(
    name = "incs",
    hdrs = ["sqlite3.h"],
    includes = ["."],
    visibility = ["//visibility:public"],
)
