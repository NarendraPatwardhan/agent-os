+static WASMInterpFrame *
+wasm_interp_find_resume_entry_frame(WASMExecEnv *exec_env)
+{
+    WASMInterpFrame *frame = wasm_exec_env_get_cur_frame(exec_env);
+
+    while (frame) {
+        if (!frame->function && !frame->ip)
+            return frame;
+        frame = frame->prev_frame;
+    }
+
+    return NULL;
+}
+
+void
+wasm_interp_resume_wasm(WASMModuleInstance *module_inst, WASMExecEnv *exec_env,
+                        uint32 result_cell_count, uint32 argv[])
+{
+    WASMInterpFrame *entry_frame, *cur_frame;
+    uint32 i;
+
+    cur_frame = wasm_exec_env_get_cur_frame(exec_env);
+    entry_frame = wasm_interp_find_resume_entry_frame(exec_env);
+    if (!cur_frame || cur_frame == entry_frame || !entry_frame) {
+        wasm_set_exception(module_inst, "no suspended wasm frame to resume");
+        return;
+    }
+
+#if defined(OS_ENABLE_HW_BOUND_CHECK) && WASM_DISABLE_STACK_HW_BOUND_CHECK == 0
+    /*
+     * wasm_runtime_detect_native_stack_overflow is done by
+     * call_wasm_with_hw_bound_check.
+     */
+#else
+    if (!wasm_runtime_detect_native_stack_overflow(exec_env)) {
+        return;
+    }
+#endif
+
+    wasm_interp_call_func_bytecode(module_inst, exec_env, NULL, NULL);
+
+    if (exec_env->wasm_call_status == WASM_RUNTIME_CALL_STATUS_YIELD)
+        return;
+
+    if (!wasm_copy_exception(module_inst, NULL)) {
+        for (i = 0; i < result_cell_count; i++)
+            argv[i] = *(entry_frame->lp + i);
+    }
+    else {
+#if WASM_ENABLE_DUMP_CALL_STACK != 0
+        if (wasm_interp_create_call_stack(exec_env)) {
+            wasm_interp_dump_call_stack(exec_env, true, NULL, 0);
+        }
+#endif
+    }
+
+    wasm_exec_env_set_cur_frame(exec_env, entry_frame->prev_frame);
+    FREE_FRAME(exec_env, entry_frame);
+#if WASM_ENABLE_OPCODE_COUNTER != 0
+    wasm_interp_dump_op_count();
+#endif
+}
