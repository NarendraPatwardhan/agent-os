+static wasm_runtime_call_status_t
+finish_interp_call_status(WASMModuleInstance *module_inst,
+                          WASMExecEnv *exec_env)
+{
+    if (exec_env->wasm_call_status == WASM_RUNTIME_CALL_STATUS_YIELD)
+        return WASM_RUNTIME_CALL_STATUS_YIELD;
+
+    if (exec_env->wasm_call_status == WASM_RUNTIME_CALL_STATUS_TRAP)
+        return WASM_RUNTIME_CALL_STATUS_TRAP;
+
+    if (wasm_copy_exception(module_inst, NULL)) {
+        exec_env->wasm_call_status = WASM_RUNTIME_CALL_STATUS_TRAP;
+        return WASM_RUNTIME_CALL_STATUS_TRAP;
+    }
+
+    exec_env->wasm_call_status = WASM_RUNTIME_CALL_STATUS_DONE;
+    return WASM_RUNTIME_CALL_STATUS_DONE;
+}
+
+wasm_runtime_call_status_t
+wasm_call_function_status(WASMExecEnv *exec_env,
+                          WASMFunctionInstance *function, unsigned argc,
+                          uint32 argv[])
 {
     WASMModuleInstance *module_inst =
         (WASMModuleInstance *)exec_env->module_inst;
@@ -3686,8 +3706,35 @@ wasm_call_function(WASMExecEnv *exec_env, WASMFunctionInstance *function,
     /* Set exec env, so it can be later retrieved from instance */
     module_inst->cur_exec_env = exec_env;
 
+    exec_env->wasm_call_status = WASM_RUNTIME_CALL_STATUS_DONE;
     interp_call_wasm(module_inst, exec_env, function, argc, argv);
-    return !wasm_copy_exception(module_inst, NULL);
+    return finish_interp_call_status(module_inst, exec_env);
+}
+
+bool
+wasm_call_function(WASMExecEnv *exec_env, WASMFunctionInstance *function,
+                   unsigned argc, uint32 argv[])
+{
+    return wasm_call_function_status(exec_env, function, argc, argv)
+           == WASM_RUNTIME_CALL_STATUS_DONE;
+}
+
+wasm_runtime_call_status_t
+wasm_resume_function(WASMExecEnv *exec_env, uint32 result_cell_count,
+                     uint32 argv[])
+{
+    WASMModuleInstance *module_inst =
+        (WASMModuleInstance *)exec_env->module_inst;
+
+#ifndef OS_ENABLE_HW_BOUND_CHECK
+    wasm_exec_env_set_thread_info(exec_env);
+#endif
+
+    module_inst->cur_exec_env = exec_env;
+
+    exec_env->wasm_call_status = WASM_RUNTIME_CALL_STATUS_DONE;
+    wasm_interp_resume_wasm(module_inst, exec_env, result_cell_count, argv);
+    return finish_interp_call_status(module_inst, exec_env);
 }
 
