+/// Structured parser output for downstream bundle renderers. Consumers can transform and verify
+/// typed tables without scraping the generated C representation.
+pub struct PreparedParser {
+    pub name: String,
+    pub tables: build_tables::Tables,
+    pub syntax_grammar: SyntaxGrammar,
+    pub lexical_grammar: LexicalGrammar,
+    pub simple_aliases: BTreeMap<Symbol, Alias>,
+    pub supertype_symbol_map: BTreeMap<Symbol, Vec<node_types::ChildType>>,
+    pub node_types_json: String,
+    pub abi_version: usize,
+    pub semantic_version: Option<(u8, u8, u8)>,
+}
+
 // NOTE: This constant must be kept in sync with the definition of
 // `TREE_SITTER_LANGUAGE_VERSION` in `lib/include/tree_sitter/api.h`.
 const LANGUAGE_VERSION: usize = 15;
