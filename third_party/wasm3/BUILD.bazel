# //third_party/wasm3 — repository-local inputs for the external wasm3 interpreter.
# Upstream source enters via MODULE.bazel's http_archive. Only our Bazel build
# file and fuel/freestanding patch live in-tree.

exports_files([
    "BUILD.wasm3.bazel",
    "patches/0001-agent-os-fuel.patch",
])

filegroup(
    name = "freestanding_headers",
    srcs = glob(["freestanding/include/*.h"]),
    visibility = ["//visibility:public"],
)

filegroup(
    name = "freestanding_libc",
    srcs = ["freestanding/libc.c"],
    visibility = ["//visibility:public"],
)
