diff --git a/source/m3_env.c b/source/m3_env.c
index d54fbc6..f513218 100644
--- a/source/m3_env.c
+++ b/source/m3_env.c
@@ -198,6 +198,63 @@ void *  m3_GetUserData  (IM3Runtime i_runtime)
     return i_runtime ? i_runtime->userdata : NULL;
 }

+#if defined(d_m3AgentOsFuelHook)
+extern M3Result agent_os_wasm3_fuel_exhausted(IM3Runtime i_runtime);
+#endif
+
+void  m3_ClearFuel  (IM3Runtime i_runtime)
+{
+    if (i_runtime)
+    {
+        i_runtime->fuel = 0;
+        i_runtime->fuelEnabled = false;
+    }
+}
+
+void  m3_SetFuel  (IM3Runtime i_runtime, u64 i_fuel)
+{
+    if (i_runtime)
+    {
+        i_runtime->fuel = i_fuel;
+        i_runtime->fuelEnabled = true;
+    }
+}
+
+void  m3_AddFuel  (IM3Runtime i_runtime, u64 i_fuel)
+{
+    if (i_runtime)
+    {
+        if (!i_runtime->fuelEnabled)
+            i_runtime->fuelEnabled = true;
+
+        i_runtime->fuel = (UINT64_MAX - i_runtime->fuel < i_fuel) ? UINT64_MAX : i_runtime->fuel + i_fuel;
+    }
+}
+
+u64  m3_GetFuel  (IM3Runtime i_runtime)
+{
+    return i_runtime ? i_runtime->fuel : 0;
+}
+
+M3Result  m3_ConsumeFuel  (IM3Runtime i_runtime, u64 i_units)
+{
+    if (i_runtime && i_runtime->fuelEnabled)
+    {
+        if (i_runtime->fuel < i_units)
+        {
+            i_runtime->fuel = 0;
+#if defined(d_m3AgentOsFuelHook)
+            return agent_os_wasm3_fuel_exhausted(i_runtime);
+#else
+            return m3Err_trapOutOfFuel;
+#endif
+        }
+        i_runtime->fuel -= i_units;
+    }
+
+    return m3Err_none;
+}
+

 void *  ForEachModule  (IM3Runtime i_runtime, ModuleVisitor i_visitor, void * i_info)
 {
