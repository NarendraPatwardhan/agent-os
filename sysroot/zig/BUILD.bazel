load("@rules_zig//zig:defs.bzl", "zig_library")

# sysroot/zig — the ZIG lane of the guest sysroot (sibling of //sysroot/rust): the shared `mc` syscall
# ABI that both luau and sqlite `@import("mc")`, so the externs can't drift between the tools;
# //tools/mc-abi-gate pins mc.zig to the projected contract (it embeds this file). svc.zig adds the
# resident-service serve-loop scaffolding (over the svc_* server syscalls) for a one-binary, two-modes
# service.

# mc.zig is also embedded by //tools/mc-abi-gate via include_str! (compile_data) — so export it.
exports_files(["mc.zig"])

zig_library(
    name = "mc",
    main = "mc.zig",
    visibility = ["//visibility:public"],
)

# The resident-service serve-loop scaffolding (serve / recv-envelope / respond) over the svc_* server
# syscalls. A Zig service `@import("svc")` and writes only its dispatch (sqlite today).
zig_library(
    name = "svc",
    main = "svc.zig",
    deps = [
        ":mc",
        "//contracts:constants_zig",  # the projected SERVICE_MARKER (codex #5), re-exported by svc.zig
    ],
    visibility = ["//visibility:public"],
)
