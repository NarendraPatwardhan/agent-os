load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")

package(default_visibility = ["//visibility:public"])

rust_library(
    name = "lib",
    srcs = ["src/lib.rs"],
    crate_name = "sidecar_helper",
    edition = "2021",
    target_compatible_with = ["@platforms//os:linux"],
    deps = ["//memcontainers/contracts:sidecar_rust"],
)

rust_binary(
    name = "sidecar-helper",
    srcs = ["src/main.rs"],
    crate_name = "agentos_sidecar_helper",
    edition = "2021",
    rustc_flags = [
        "-Cstrip=symbols",
        "-Ctarget-feature=+crt-static",
    ],
    target_compatible_with = ["@platforms//os:linux"],
    deps = [":lib"],
)

rust_test(
    name = "test",
    srcs = ["src/lib.rs"],
    crate_name = "sidecar_helper_test",
    edition = "2021",
    target_compatible_with = ["@platforms//os:linux"],
    deps = ["//memcontainers/contracts:sidecar_rust"],
)

exports_files(["sidecar-helper.conf"])
