load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_test")
load("@rules_zig//zig:defs.bzl", "zig_binary", "zig_configure_binary")

package(default_visibility = ["//visibility:public"])

zig_binary(
    name = "health_guest_raw",
    main = "guest.zig",
    deps = ["//memcontainers/contracts:runner_zig"],
    tags = ["manual"],
)

zig_configure_binary(
    name = "health_guest",
    actual = ":health_guest_raw",
    mode = "release_small",
    threaded = "single",
    tags = ["manual"],
)

rust_binary(
    name = "mkinitramfs",
    srcs = ["mkinitramfs.rs"],
    edition = "2021",
)

rust_test(
    name = "mkinitramfs_test",
    srcs = ["mkinitramfs.rs"],
    edition = "2021",
)

genrule(
    name = "health_initramfs",
    srcs = [":health_guest"],
    outs = ["health-initramfs.cpio"],
    cmd = "$(location :mkinitramfs) $(location :health_guest) $@",
    tools = [":mkinitramfs"],
)
