load("@rules_rust//rust:defs.bzl", "rust_test")

# tests/parity — the parity GRID (SYSTEMS.md, B7). Two axes compose:
#
#                  Rust host          JS host
#     Rust kernel   ✓ (Phase A)        ✓ (Phase A)
#     Zig kernel    ✓ (Phase B)        ✓ (Phase B)
#
# Every cell runs the identical suite against real artifacts; any disagreement is a bug
# in a host, a kernel, or an UNDERSPECIFIED contract — all three worth catching. The
# two-kernel column is the Phase-B acceptance gate: the Zig kernel ships only when it
# matches the Rust kernel bit-for-bit on the shared e2e + conformance suite — by parity,
# never by inspection (B7). Amplified by record/replay (SYSTEMS.md section 14.2) and differential fuzzing
# (SYSTEMS.md section 14.2), both using the Rust kernel as the oracle.
#
# The behavioral Rust-vs-Zig DIFF matrix lands in Phase 7 (ZIG_KERNEL §8) — it needs the
# Zig kernel to first pass real scenarios (Phases 3-6). Until then, this package holds the
# artifact-level "the Zig kernel is a faithful drop-in for Rust" gates: it obeys the same
# host boundary (imports only `env`, exports only the control surface + optional asyncify_*)
# and loads in the SAME stock wasmtime host with no Zig special-casing (ZIG_KERNEL §7.7).

# Import/export purity of the post-Asyncify Zig kernel.wasm (§8 Phase 1, §1.2). Imports only
# declared `env` symbols (A4); exports only the generated control surface + the optional
# asyncify_* set — no host-callable suspend-driving export (no mc_prepare_rewind, §15.2).
rust_test(
    name = "zig_purity_test",
    srcs = ["src/purity_test.rs"],
    crate_root = "src/purity_test.rs",
    edition = "2021",
    data = ["//memcontainers/kernel/zig:kernel"],
    deps = [
        "//bazel/tools/wasm-imports:lib",
        "//memcontainers/contracts:ctl_rust",
        "//memcontainers/contracts:env_rust",
        "@host_crates//:anyhow",
        "@host_crates//:wasmparser",
        "@rules_rust//rust/runfiles",
    ],
)

# The STOCK wasmtime host (the exact one the Rust kernel boots, no Zig special-casing)
# instantiates the Zig kernel, runs mc_init, and ticks without trapping (§8 Phase 1, §7.7).
rust_test(
    name = "zig_host_instantiate_test",
    srcs = ["src/host_instantiate_test.rs"],
    crate_root = "src/host_instantiate_test.rs",
    edition = "2021",
    data = ["//memcontainers/kernel/zig:kernel"],
    deps = [
        "//memcontainers/hosts/wasmtime:host",
        "@rules_rust//rust/runfiles",
    ],
)
