load("@rules_rust//rust:defs.bzl", "rust_shared_library")
load("//memcontainers/hosts/wasmtime:defs.bzl", "host_release_shared_library")

# host_nif — the BEAM-loadable NIF that wraps the wasmtime `host` library (//memcontainers/
# hosts/wasmtime:host), exposing the existing Rust host to Elixir WITHOUT re-implementing
# the `env` bridge. One supervised BEAM process owns one KernelHost via a
# Rustler ResourceArc; boot/tick/exec run on a DirtyCpu scheduler.
#
# Native cdylib (`libhost_nif.so`), built by Bazel — NOT by mix's rustler compilation. The
# //server control plane `data`-depends on it and loads it from priv/. `rustler` comes from its
# own @nif_crates universe (//MODULE.bazel); the wasmtime embedding comes from `:host`.
#
# `manual`: this is the intermediate cdylib that `host_nif_release` transitions to opt and
# re-exports. Both emit `libhost_nif.so` in this package, so leaving it in the `//...` wildcard
# makes the two actions collide on the same output path at the top-level config. Mirrors the
# kernel's `release_wasm`-wrapped `:lib` (also `manual`). The release wrapper still builds it
# transitively, so nothing that consumes `host_nif_release` is affected.
rust_shared_library(
    name = "host_nif",
    srcs = ["src/lib.rs"],
    edition = "2021",
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [
        "//memcontainers/contracts:constants_rust",
        "//memcontainers/contracts:ctl_rust",
        "//memcontainers/contracts:sidecar_rust",
        "//memcontainers/hosts/wasmtime:host",
        "@nif_crates//:rustler",
    ],
)

# The distributable BEAM NIF is always release/opt, even when a caller builds the package from
# Bazel's default fastbuild configuration. This mirrors //memcontainers/hosts/wasmtime:mc:
# wasmtime/cranelift debug builds are not the runtime we ship.
host_release_shared_library(
    name = "host_nif_release",
    lib = ":host_nif",
    out = "libhost_nif.so",
    visibility = ["//visibility:public"],
)
