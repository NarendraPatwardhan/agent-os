load("//bazel:ts.bzl", "mc_ts_project")
load("@aspect_rules_js//js:defs.bzl", "js_test")
load("@aspect_rules_js//npm:defs.bzl", "npm_package")
load("@npm//:defs.bzl", "npm_link_all_packages")

# Link @mc/host's own deps (@mc/contracts) into :node_modules/*.
npm_link_all_packages(name = "node_modules")

# hosts/js — the TypeScript host for bun + the browser, the second host family (A3). It loads the
# SAME kernel.wasm as hosts/wasmtime and behaves identically; async JS drives the synchronous-looking
# kernel over the poll bridge. The `env` bridge and the `mc_ctl_*` export lookup are wired from the
# generated @mc/contracts descriptors, so the boundary the kernel/Rust host derive from is the one the
# JS host derives from too — it can't silently desync (B2).
mc_ts_project(
    name = "host",
    srcs = glob(["src/**/*.ts"]),
    deps = [
        ":node_modules/@mc/contracts",  # BRIDGE_IMPORTS / CONTROL_EXPORTS / errnos — by name, no reach-in
        "//:node_modules/@types/bun",  # process, node:fs/node:path globals (the node/bun durability path)
    ],
    visibility = ["//visibility:public"],
)

# @mc/host as a linkable workspace package, so @mc/core imports it BY NAME instead of reaching into
# hosts/js/src with a deep relative path. Bundles the compiled host; package.json points at the
# built .js/.d.ts.
npm_package(
    name = "pkg",
    srcs = [
        ":host",
        "package.json",
    ],
    package = "@mc/host",
    visibility = ["//visibility:public"],
)

# A3 two-host parity: the SAME kernel.wasm + base.tar the wasmtime e2e boots, driven by THIS host.
# data-deps the kernel + image (the load-bearing edge: the artifacts a test runs are the ones its
# sources produce) and passes their runfiles paths via env, exactly like the Rust e2e.
mc_ts_project(
    name = "parity_lib",
    srcs = ["test/parity.test.ts"],
    deps = [
        ":host",
        "//:node_modules/@types/bun",
    ],
)

js_test(
    name = "parity_test",
    data = [
        ":parity_lib",
        "//memcontainers/kernel/rust:kernel",
        "//memcontainers/images:base",
    ],
    entry_point = "test/parity.test.js",
    env = {
        "MC_KERNEL_WASM": "$(rlocationpath //memcontainers/kernel/rust:kernel)",
        "MC_BASE_IMAGE": "$(rlocationpath //memcontainers/images:base)",
    },
)

# Persist capability unit coverage: the JS host's disk/browser backends implement
# the same async `start/poll/body/close` ABI as wasmtime. This target exercises
# the codec and the browser durability/ordering semantics without booting a VM.
mc_ts_project(
    name = "persist_lib",
    srcs = ["test/persist.test.ts"],
    deps = [
        ":host",
        ":node_modules/@mc/contracts",
        "//:node_modules/@types/bun",
    ],
)

js_test(
    name = "persist_test",
    data = [":persist_lib"],
    entry_point = "test/persist.test.js",
)

# Cross-host policy parity (A3): the SAME vector file the Rust
# //memcontainers/hosts/wasmtime:policy_parity_test consumes drives policy.ts here, so the two
# independent policy engines cannot drift in resolution or which patterns they reject.
mc_ts_project(
    name = "policy_parity_lib",
    srcs = ["test/policy-parity.test.ts"],
    deps = [
        ":host",
        "//:node_modules/@types/bun",
    ],
)

# The canonical shared parity vectors. Exported so the Rust
# //memcontainers/hosts/wasmtime:policy_parity_test consumes the identical file cross-package.
exports_files(
    ["test/policy_parity.json"],
    visibility = ["//visibility:public"],
)

js_test(
    name = "policy_parity_test",
    data = [
        ":policy_parity_lib",
        "test/policy_parity.json",
    ],
    entry_point = "test/policy-parity.test.js",
    env = {
        "MC_POLICY_VECTORS": "$(rlocationpath test/policy_parity.json)",
    },
)

# Cross-host parity (A3/A8): rehydrate a snapshot the WASMTIME host produced
# (//memcontainers/hosts/wasmtime:cross_host_snapshot) under THIS host, asserting the saved state and a
# live exec survive. The strongest proof the MCSN format is truly host-identical — not same-host only.
mc_ts_project(
    name = "cross_host_lib",
    srcs = ["test/cross-host.test.ts"],
    deps = [
        ":host",
        "//:node_modules/@types/bun",
    ],
)

js_test(
    name = "cross_host_test",
    data = [
        ":cross_host_lib",
        "//memcontainers/kernel/rust:kernel",
        "//memcontainers/hosts/wasmtime:cross_host_snapshot",
    ],
    entry_point = "test/cross-host.test.js",
    env = {
        "MC_KERNEL_WASM": "$(rlocationpath //memcontainers/kernel/rust:kernel)",
        "MC_CROSS_SNAPSHOT": "$(rlocationpath //memcontainers/hosts/wasmtime:cross_host_snapshot)",
    },
)
