{
  "_comment": "Shared parity vectors for the host-side tool policy engine. The Rust (policy.rs) and TS (policy.ts) implementations BOTH consume this file and must agree on every case. The egress splice resolves rules against a connection address `integration.owner.connection.*`, so resolve cases use that shape. `expect` is the resolved action or null for no match.",
  "resolve": [
    {
      "name": "no rules -> no match",
      "rules": [],
      "address": "github.org.main.*",
      "expect": null
    },
    {
      "name": "universal wildcard matches",
      "rules": [{ "owner": "org", "pattern": "*", "action": "block" }],
      "address": "github.org.main.*",
      "expect": "block"
    },
    {
      "name": "integration-level wildcard matches",
      "rules": [{ "owner": "org", "pattern": "github.*", "action": "require_approval" }],
      "address": "github.org.main.*",
      "expect": "require_approval"
    },
    {
      "name": "owner-level wildcard matches",
      "rules": [{ "owner": "user", "pattern": "github.org.*", "action": "approve" }],
      "address": "github.org.main.*",
      "expect": "approve"
    },
    {
      "name": "connection-level wildcard matches",
      "rules": [{ "owner": "org", "pattern": "github.org.main.*", "action": "block" }],
      "address": "github.org.main.*",
      "expect": "block"
    },
    {
      "name": "different connection does not match",
      "rules": [{ "owner": "org", "pattern": "github.org.other.*", "action": "block" }],
      "address": "github.org.main.*",
      "expect": null
    },
    {
      "name": "different integration does not match",
      "rules": [{ "owner": "org", "pattern": "gitlab.*", "action": "block" }],
      "address": "github.org.main.*",
      "expect": null
    },
    {
      "name": "first match per owner wins (org): earlier approve beats later block for the same owner",
      "rules": [
        { "owner": "org", "pattern": "github.org.main.*", "action": "approve" },
        { "owner": "org", "pattern": "github.*", "action": "block" }
      ],
      "address": "github.org.main.*",
      "expect": "approve"
    },
    {
      "name": "most restrictive across owners: org=approve, user=block -> block",
      "rules": [
        { "owner": "org", "pattern": "github.*", "action": "approve" },
        { "owner": "user", "pattern": "github.org.main.*", "action": "block" }
      ],
      "address": "github.org.main.*",
      "expect": "block"
    },
    {
      "name": "most restrictive across owners: org=approve, user=require_approval -> require_approval",
      "rules": [
        { "owner": "org", "pattern": "github.org.main.*", "action": "approve" },
        { "owner": "user", "pattern": "github.*", "action": "require_approval" }
      ],
      "address": "github.org.main.*",
      "expect": "require_approval"
    },
    {
      "name": "first-match-per-owner then most-restrictive: org first=approve (ignores later org block), user=require_approval -> require_approval",
      "rules": [
        { "owner": "org", "pattern": "github.org.main.*", "action": "approve" },
        { "owner": "org", "pattern": "github.*", "action": "block" },
        { "owner": "user", "pattern": "github.*", "action": "require_approval" }
      ],
      "address": "github.org.main.*",
      "expect": "require_approval"
    }
  ],
  "reject": [
    {
      "name": "per-tool pattern (concrete 4th segment) is unenforceable at the splice -> rejected",
      "rule": { "owner": "org", "pattern": "github.org.main.delete-repo", "action": "block" }
    },
    {
      "name": "per-tool trailing-wildcard (5 segments) -> rejected",
      "rule": { "owner": "org", "pattern": "github.org.main.issues.*", "action": "block" }
    },
    {
      "name": "exact (non-wildcard) pattern can never match the splice address -> rejected",
      "rule": { "owner": "org", "pattern": "github.org.main", "action": "block" }
    },
    {
      "name": "invalid owner -> rejected",
      "rule": { "owner": "admin", "pattern": "github.*", "action": "block" }
    },
    {
      "name": "invalid action -> rejected",
      "rule": { "owner": "org", "pattern": "github.*", "action": "deny" }
    },
    {
      "name": "empty segment -> rejected",
      "rule": { "owner": "org", "pattern": "github..main.*", "action": "block" }
    }
  ]
}
