load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

# A lightweight, pure no_std alternative to serde_json (parse + serialize), shared across agent-os
# Rust components — hence the `:serde` target. It imports as the `json` crate (crate_name), so it never
# shadows the real serde. No syscalls, no external deps; the kernel/guest supplies the heap (alloc).
# The kernel reads /etc/services.json to activate resident services; userspace tools (e.g.
# //memcontainers/programs/invoke) can parse tool-call results rather than only hand-building request bodies. Under
# `--test` the crate links std (the source is `#![cfg_attr(not(test), no_std)]`), so the unit tests run
# natively. Ported from memcontainers' agentcore JSON core, with a Json→String serializer added.
rust_library(
    name = "serde",
    srcs = ["src/lib.rs"],
    crate_name = "json",
    edition = "2021",
    visibility = ["//visibility:public"],
)

# The pure logic, unit-tested natively: parse primitives/nesting/errors, the service-manifest shape,
# and serialize round-trips.
rust_test(
    name = "test",
    crate = ":serde",
    edition = "2021",
    size = "small",
)
