load("@rules_rust//rust:defs.bzl", "rust_shared_library")
load("@bazel_skylib//rules:build_test.bzl", "build_test")
load("//bazel/tools/size:defs.bzl", "size_limit")
load("//bazel:release_wasm.bzl", "release_wasm")
load("//bazel:wasm_opt.bzl", "wasm_opt")

# kernel/rust — the shipped kernel, ported from memcontainers rather than rewritten.
# It compiles to wasm32-unknown-unknown and uses wasmi as an ordinary native Rust crate,
# with no C seam or Asyncify transform (SYSTEMS.md §4).
#
# We ship ONE kernel: the cooperative build. Every guest runs on the cooperative
# scheduler; the `threads` feature only WRAPS that scheduler in a Big Kernel Lock + worker
# exports for a future shared-memory multi-worker host, which does not exist yet — so it
# is left off (the `#[cfg(feature = "threads")]` gates stay in the source, a one-flag
# re-enable when such a host lands). The shipped artifact is ALWAYS release: `release_wasm`
# pins the whole subgraph to opt, the cdylib is symbol-stripped, and `wasm_opt` applies the common
# post-link policy, so `//memcontainers/kernel/rust:kernel` is the small artifact, never a multi-MB
# debug build.

# The cdylib. Tagged manual: a no_std cdylib has no host runtime, so `//...` builds it only through the
# release_wasm transition below, which pins the size-opt GRAPH-WIDE (opt-level=z, fat LTO, panic=abort,
# one codegen unit — SYSTEMS.md); here we only strip the symbol/name tables from the shipped wasm.
rust_shared_library(
    name = "lib",
    srcs = glob(["src/**/*.rs"]),
    edition = "2024",
    rustc_flags = [
        "-Cstrip=symbols",  # drop the symbol/name tables (opt-level/LTO/panic are pinned by the transition)
    ],
    tags = ["manual"],
    deps = [
        "@crates//:wasmi",  # eager-mode =1.0.9 (the landmine), native dep
        "@crates//:wasmparser",  # engine-free validation before permanent wasmi arena admission
        "@crates//:talc",   # wasm linear-memory allocator (A8: all state in linear mem)
        "//memcontainers/contracts:constants_rust",  # errno / caps / tiers / flags / signals (B2)
        "//memcontainers/contracts:mc_rust",         # the mc_syscall_table! macro + SYSCALL_NAMES (B2)
        "//memcontainers/contracts:shell_rust",      # resident /bin/sh probe/render boundary (B2)
        "//memcontainers/contracts:env_rust",        # the mc_bridge_table! macro → the env extern block (B2)
        "//memcontainers/contracts:ctl_rust",        # the mc_control_table! macro → the mc_ctl_* exports (B2)
        "//memcontainers/lib/json:lib",              # no_std JSON: read /etc/services.d fragments for service activation
        "//memcontainers/pkgcore:lib",               # no_std SHA-256 for toolsfs shard integrity checks
        "//memcontainers/toolcore:lib",              # no_std tool catalog parser for the read-only /tools tree
    ],
)

# The compiler-stage kernel: always opt + wasm32 + stripped. Kept private; the rest of the graph
# consumes only the post-link-optimized //memcontainers/kernel/rust:kernel (B1).
release_wasm(
    name = "kernel_release",
    lib = ":lib",
    size_opt = True,  # the size-gated artifact carries the full B5 size-opt (LTO + panic=abort)
)

# The shipped artifact: e2e / parity / conformance all data-depend on this exact output (B1).
wasm_opt(
    name = "kernel",
    wasm = ":kernel_release",
    visibility = ["//visibility:public"],
)

# B5 size budget gate (the shared //bazel/tools/size rule) — a regression past the ceiling fails CI rather than
# silently bloating the agent's footprint. memcontainers ships ~1.67 MB; we carry the resident-service
# (svc) subsystem it lacks, but the B5 size-opt (LTO + panic=abort) more than pays for it — the artifact
# is ~1.11 MB after post-link optimization. Hold the ceiling tight enough to catch a meaningful
# regression while leaving room for intentional kernel growth.
size_limit(
    name = "size_limit",
    file = ":kernel",
    max_bytes = 1200000,
)

# Anchors the kernel in the test graph: asserts kernel.wasm builds.
build_test(
    name = "build_test",
    targets = [":kernel"],
)
