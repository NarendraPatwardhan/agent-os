# The embedded WAMR interpreter foundation (PERFORMANCE.md §8), compiled freestanding by zig cc
# into the kernel. Its libc/platform surface is satisfied in-module
# (third_party/wamr/freestanding), never as a new host import (A4, verified by import-purity).
# The Zig guest driver still needs the follow-up WAMR port before this kernel target compiles.
WAMR_CSRC = [
    "//third_party/wamr:freestanding_libc",
    "//third_party/wamr:freestanding_platform",
    "@wamr//:core_srcs",
]
WAMR_EXTRA_SRCS = [
    "//third_party/wamr:freestanding_headers",
    "@wamr//:headers",
]
WAMR_COPTS = [
    "-DWASM_ENABLE_INTERP=1",
    "-DWASM_ENABLE_FAST_INTERP=1",
    "-DWASM_ENABLE_INSTRUCTION_METERING=1",
    "-DWASM_ENABLE_AOT=0",
    "-DWASM_ENABLE_JIT=0",
    "-DWASM_ENABLE_FAST_JIT=0",
    "-DWASM_ENABLE_THREAD_MGR=0",
    "-DWASM_ENABLE_SHARED_MEMORY=0",
    "-DWASM_ENABLE_LIBC_WASI=0",
    "-DWASM_ENABLE_LIBC_BUILTIN=0",
    "-DWASM_ENABLE_MULTI_MODULE=0",
    "-DWASM_ENABLE_GC=0",
    "-DWASM_ENABLE_BULK_MEMORY=1",
    "-DBH_MALLOC=wasm_runtime_malloc",
    "-DBH_FREE=wasm_runtime_free",
    "-Ithird_party/wamr/freestanding/include",
    "-fdata-sections",
    "-ffunction-sections",
    "-fvisibility=hidden",
]

# The reactor module: exports only, no _start. Reachable files compile; the rest are
# declared inputs the fill phases import as they land (§15.1). Tagged manual — it is only
# meaningful under the wasm transition (building it for the host has no entry point).
zig_binary(
    name = "kernel_raw",
    main = "src/main.zig",
    srcs = KERNEL_SRCS,
    copts = WAMR_COPTS,
    csrcs = WAMR_CSRC,
    extra_srcs = WAMR_EXTRA_SRCS,
    # Keep the wasm name section (ReleaseSmall strips it by default): Binaryen's
    # The legacy asyncify gates match functions BY NAME, so without names they instrument
    # nothing and the suspend/resume check becomes meaningless (§7.4). The name section is
    # kept until the WAMR driver phase deletes the asyncify machinery.
    zigopts = ["-fno-strip"],
    linkopts = [
        "-fno-entry",
        "-rdynamic",
    ],
    tags = ["manual"],
    deps = [
        "//memcontainers/contracts:constants_zig",  # errno/caps/tiers/flags (B2)
        "//memcontainers/contracts:env_zig",  # bridge.zig derives the env extern surface from IMPORTS (§5.1)
        "//memcontainers/contracts:mc_zig",  # generated syscall descriptors + Pending union (§5.1)
        "//memcontainers/shcore:shcore",
        "@wamr//:incs",  # WAMR include path for the freestanding C compile
        # ctl_zig / mc_zig join as control-exec (Phase 4) and syscall.zig (Phase 5) consume their
        # descriptors. The two tiny FileStat/DirEntries result frames are hand-encoded in control.zig
        # against the control.kdl wire format (constants there gate drift) — see wire_test.
    ],
)

# Transition to wasm32-freestanding, size-optimised — the exact lane every kernel/guest uses.
zig_configure_binary(
    name = "kernel_obj",
    actual = ":kernel_raw",
    mode = "release_small",
    tags = ["manual"],
    target = "//platforms:wasm32_freestanding",
    threaded = "single",  # the kernel is cooperative/single-threaded (A7); enables WasmAllocator
)

# The shipped kernel artifact every consumer data-depends on (B1): kernel_obj through the
# Asyncify transition (§6.2, §7.4). The only_list is the scoped instrument set — the whole
# point of the port (§15.2): it is a NON-EMPTY WHITELIST (never []), so ONLY these frames are
# instrumented. The guest.zig driver frame is excluded simply by being absent from the list,
# which is exactly what lets it catch the unwind INTERNALLY (§7.4) — Binaryen forbids pairing
# an only-list with a remove-list, so omission IS the pin. On the pre-driver kernel there are no
# suspend points, so this instruments nothing. The WAMR follow-up removes this path in favor
# of exec_env re-entry and metering. The host is never modified; there is no mc_prepare_rewind
# (§7.7). Adds only the optional asyncify_* exports (allowed by §1.2).
asyncify_wasm(
    name = "kernel",
    src = ":kernel_obj",
    # ignore_indirect MUST stay off for the legacy asyncify path: interpreter dispatch and
    # raw-function trampolines use CALL_INDIRECT, and slim proved that ignoring indirect
    # calls "re-entered the pcall import instead of resuming the continuation" — it breaks
    # nested-m3_Call resumption, the core of mc.pcall / loom programmability. The unwind
    # propagates back up the indirect op chain, so those sites must be instrumented (with it on,
    # the unwind cannot cross them and hits an Asyncify-inserted `unreachable` at the first
    # suspend — the stdin-read block).
    ignore_indirect = False,
    # §7.4 internal catch as a REMOVE-list (blacklist), NOT a whitelist. Asyncify instruments
    # EVERY function that can reach a suspend EXCEPT those named here — the future-proof choice
    # for programmability: mc.pcall runs a guest inside a guest (a nested m3_Call, slim 4e4d3da),
    # and any such new suspend path is auto-instrumented. A whitelist would have to re-enumerate
    # the pcall handler + every suspend helper and would SILENTLY break loom on a miss.
    # Excluded:
    #   agent_os_guest_call_boundary — the ONE Asyncify catch: the unwind spills up the whole
    #     interpreter op chain + raw handlers + nested guest calls + the syscall/fuel suspend
    #     helpers (all auto-instrumented) and STOPS here, which calls asyncify_stop_unwind and returns to the
    #     scheduler — the host never sees a suspend, and there is no mc_prepare_rewind.
    #   main.mc_*  — every host-called export, kept OUT of instrumentation so the host boundary
    #     is provably clean (no export can carry an unwind to the host). mc_tick reaches the
    #     guest only THROUGH the catch frame, so it is never on a live unwind anyway.
    # Cost: ignore_indirect=False conservatively marks the VFS/control plane (vtable indirect
    # calls) instrumentable — dead instrumentation (those paths never call start_unwind), a size
    # cost for Phase 8, not a correctness issue. no-creep asserts the excluded set is state 0.
    remove_list = ASYNCIFY_REMOVE_LIST,
    tail_call_list = ASYNCIFY_TAIL_CALL_LIST,
    visibility = ["//visibility:public"],
)

# B5 size gate — loose while incomplete, read against the shipped artifact. Tightens
# post-parity; once Asyncify lands it measures the Asyncified wasm (its real cost, §12.2).
size_limit(
    name = "size_limit",
    file = ":kernel",
    max_bytes = KERNEL_MAX_BYTES,
)

# Anchors the kernel in the test graph: asserts the freestanding wasm actually builds.
build_test(
    name = "test",
    targets = [":kernel"],
)

# The import/export-purity and host-instantiate gates (rust_test SOURCES) live under
# //memcontainers/tests/parity:zig_purity_test and :zig_host_instantiate_test — kernel test
# sources do not belong in the kernel package (kernel/rust has no tests/ dir either). The
# build-rule gates below stay here because they are source/artifact checks local to this
# package, like size_limit — they carry no .rs sources.

# ── Asyncify no-creep gate (§7.4, §9, §15.6) ──────────────────────────────────────────
# The §7.4 internal catch is a REMOVE-list, so "no creep" flips to three invariants on the
# SHIPPED wasm + the Asyncify verbose stream: (1) the ONE catch frame still exists as a named
# function to be pinned (an inlined pin silently escapes — and Binaryen does NOT warn on a
# non-matching remove_list entry); (2) no host-callable mc_prepare_rewind export (the host
# never drives Asyncify, §7.7); (3) no host IMPORT becomes a suspend-driver (only the Asyncify
# intrinsics may change state through an import, A4). The end-to-end proof that the catch
# actually fires is //memcontainers/tests/e2e:core_zig (boot_reaches_login_prompt).
filegroup(
    name = "kernel_asyncify_verbose",
    srcs = [":kernel"],
    output_group = "asyncify_verbose",
)

filegroup(
    name = "kernel_asyncify_manifest",
    srcs = [":kernel"],
    output_group = "asyncify_manifest",
)

genrule(
    name = "asyncify_no_creep_check",
    srcs = [
        ":kernel",
        ":kernel_asyncify_manifest",
        ":kernel_asyncify_verbose",
    ],
    tools = [
        "asyncify_no_creep.sh",
        "@binaryen_linux_x86_64//:bin/wasm-dis",
    ],
    outs = ["asyncify_no_creep.ok"],
    cmd = """
set -eu
wasm="$(location :kernel)"
manifest="$(location :kernel_asyncify_manifest)"
verbose="$(location :kernel_asyncify_verbose)"
bash "$(location asyncify_no_creep.sh)" "$$wasm" "$$verbose" "$(location @binaryen_linux_x86_64//:bin/wasm-dis)" "$$manifest" "$@"
""",
)

build_test(
    name = "asyncify_no_creep_test",
    targets = [":asyncify_no_creep_check"],
)

# ── Scaffold-shape gate (§15.1, §15.7) ───────────────────────────────────────────────
# Mechanically forbids the first attempt's two production sins: a *_smoke/*_probe source
# in the kernel, and an embedded guest fixture / self-test symbol (@embedFile /
# bootSelfCheck) in production code. A violation fails `bazel test`.
genrule(
    name = "scaffold_shape_check",
    srcs = KERNEL_SRCS + ["src/main.zig"],
    outs = ["scaffold_shape.ok"],
    cmd = """
set -eu
viol=0
for f in $(SRCS); do
  case "$$f" in
    *_smoke*|*_probe*) echo "FAIL: smoke/probe source in kernel: $$f (ZIG_KERNEL §15.7)"; viol=1 ;;
  esac
  if grep -q '@embedFile' "$$f"; then echo "FAIL: embedded fixture (@embedFile) in production: $$f (§15.7)"; viol=1; fi
  if grep -q 'bootSelfCheck' "$$f"; then echo "FAIL: self-test symbol (bootSelfCheck) in production: $$f (§15.7)"; viol=1; fi
done
if [ "$$viol" != 0 ]; then exit 1; fi
echo ok > $@
""",
)

build_test(
    name = "scaffold_shape_test",
    targets = [":scaffold_shape_check"],
)
