load("@rules_zig//zig:defs.bzl", "zig_binary", "zig_configure_binary")
load("@bazel_skylib//rules:build_test.bzl", "build_test")
load("//bazel:asyncify.bzl", "asyncify_wasm")
load("//bazel/tools/size:defs.bzl", "size_limit")

# kernel/zig — the parity-gated Zig kernel from ZIG_KERNEL.md. The Rust kernel remains
# the oracle/default (B7); Zig ships only by matching it on the shared suite. This file
# is the CONCRETE SCAFFOLD (§15.1): the §4.1 module map exists as empty contract-headed
# files, wired into a buildable freestanding wasm, so the implementer fills named blanks
# and never invents structure. Fill order: §13.
#
# Phase 1 is DONE here: the freestanding kernel passes the Asyncify transition (via
# bazel/asyncify.bzl, non-empty only_list — never []) and carries the import/export-purity
# and size gates. On the no-wasm3 kernel nothing suspends, so Asyncify instruments nothing
# and the only_list matches nothing yet — that is the honest "no wasm3 yet" Phase 1 (§8).
#
# WHAT IS DELIBERATELY NOT HERE YET (cherry-picked from agent-os-slim in Phase order, §15.5):
#   - //third_party/wasm3 (http_archive + fuel patch) + its freestanding libc — Phase 5.
#     When it lands: add csrcs/copts (-Dd_m3AgentOsFuelHook=1, -Dd_m3AgentOsAllocator=1)
#     + @wasm3//:incs to kernel_raw, filling src/wasm3/* and src/guest.zig; and the
#     only_list/remove_list below get their REAL wasm3-op + trampoline + driver-frame names.
#   - the generated ctl_zig/env_zig/mc_zig deps — added to kernel_raw as control.zig /
#     bridge.zig / syscall.zig get filled (constants_zig is used from day one).

# Loose scaffold ceiling; measured post-Asyncify and tightened after parity, not before (B5).
KERNEL_MAX_BYTES = 1024 * 1024

# The §7.4 Asyncify catch boundary, as a REMOVE-list (full rationale on the asyncify_wasm
# call): Asyncify instruments EVERY function that can reach a suspend EXCEPT these — the ONE
# catch frame and every host export stay uninstrumented, so the guest unwind is caught inside
# the kernel and the host boundary is provably clean. Future suspend paths (mc.pcall's nested
# m3_Call → loom) are instrumented by construction, never by re-enumeration. no-creep asserts
# each entry actually MATCHES a real function (an inlined catch frame would silently escape).
ASYNCIFY_REMOVE_LIST = [
    "agent_os_guest_call_boundary",
    "main.mc_*",
]

# The §4.1 module map, declared EXPLICITLY (never globbed): the scaffold-shape gate below
# asserts this set carries no *_smoke/*_probe/fixture file (§15.7). Adding a source here is
# a reviewed act — that is the anti-sprawl mechanism the first attempt lacked.
KERNEL_SRCS = [
    "src/state.zig",
    "src/control.zig",
    "src/bridge.zig",
    "src/boot.zig",
    "src/task.zig",
    "src/scheduler.zig",
    "src/guest.zig",
    "src/rescue.zig",
    "src/syscall.zig",
    "src/vfs.zig",
    "src/wasm3/bindings.zig",
    "src/wasm3/alloc.zig",
    "src/wasm3/raw.zig",
    "src/ipc/pipe.zig",
    "src/egress/net.zig",
    "src/egress/host_call.zig",
    "src/egress/persist.zig",
    "src/service/registry.zig",
    "src/fs/memfs.zig",
    "src/fs/tarfs.zig",
    "src/fs/cowfs.zig",
    "src/fs/overlayfs.zig",
    "src/fs/devfs.zig",
    "src/fs/envfs.zig",
    "src/fs/procfs.zig",
    "src/fs/netfs.zig",
    "src/fs/persistfs.zig",
    "src/fs/servedfs.zig",
    "src/fs/servicefs.zig",
    "src/fs/mountfs.zig",
    "src/fs/toolsfs.zig",
    "src/fs/proxy.zig",
    "src/fs/utils.zig",
]

# The embedded wasm3 interpreter (ZIG_KERNEL §7), compiled freestanding by zig cc into the
# kernel. Its libc surface is satisfied in-module (third_party/wasm3/freestanding), never as
# a new host import (A4, verified by import-purity). The fuel-metering patch is on
# (d_m3AgentOsFuelHook); allocation routes to wasm3/alloc.zig (d_m3AgentOsAllocator, A6).
WASM3_CSRC = [
    "//third_party/wasm3:freestanding_libc",
    "@wasm3//:core_srcs",
]
WASM3_EXTRA_SRCS = [
    "//third_party/wasm3:freestanding_headers",
    "@wasm3//:headers",
]
WASM3_COPTS = [
    "-Dd_m3AgentOsAllocator=1",
    "-Dd_m3Freestanding=1",
    "-Dd_m3VerboseErrorMessages=0",
    "-Dd_m3RecordBacktraces=0",
    "-Dd_m3EnableStrace=0",
    "-Dd_m3AgentOsFuelHook=1",
    "-Ithird_party/wasm3/freestanding/include",
    "-fdata-sections",
    "-ffunction-sections",
    "-fvisibility=hidden",
]

# The reactor module: exports only, no _start. Reachable files compile; the rest are
# declared inputs the fill phases import as they land (§15.1). Tagged manual — it is only
# meaningful under the wasm transition (building it for the host has no entry point).
zig_binary(
    name = "kernel_raw",
    main = "src/main.zig",
    srcs = KERNEL_SRCS,
    copts = WASM3_COPTS,
    csrcs = WASM3_CSRC,
    extra_srcs = WASM3_EXTRA_SRCS,
    # Keep the wasm name section (ReleaseSmall strips it by default): Binaryen's
    # asyncify-onlylist matches wasm3's functions BY NAME, so without names it instruments
    # nothing and the suspend/resume is silently a no-op (§7.4). The name section is a few
    # tens of KB, well under the size budget; the asyncify no-creep gate keeps it honest.
    zigopts = ["-fno-strip"],
    linkopts = [
        "-fno-entry",
        "-rdynamic",
    ],
    tags = ["manual"],
    deps = [
        "//memcontainers/contracts:constants_zig",  # errno/caps/tiers/flags (B2)
        "//memcontainers/contracts:env_zig",  # bridge.zig derives the env extern surface from IMPORTS (§5.1)
        "//memcontainers/contracts:mc_zig",  # generated syscall descriptors + Pending union (§5.1)
        "//memcontainers/shcore:shcore",
        "@wasm3//:incs",  # wasm3.h include path for the freestanding C compile
        # ctl_zig / mc_zig join as control-exec (Phase 4) and syscall.zig (Phase 5) consume their
        # descriptors. The two tiny FileStat/DirEntries result frames are hand-encoded in control.zig
        # against the control.kdl wire format (constants there gate drift) — see wire_test.
    ],
)

# Transition to wasm32-freestanding, size-optimised — the exact lane every kernel/guest uses.
zig_configure_binary(
    name = "kernel_obj",
    actual = ":kernel_raw",
    mode = "release_small",
    tags = ["manual"],
    target = "//platforms:wasm32_freestanding",
    threaded = "single",  # the kernel is cooperative/single-threaded (A7); enables WasmAllocator
)

# The shipped kernel artifact every consumer data-depends on (B1): kernel_obj through the
# Asyncify transition (§6.2, §7.4). The only_list is the scoped instrument set — the whole
# point of the port (§15.2): it is a NON-EMPTY WHITELIST (never []), so ONLY these frames are
# instrumented. The guest.zig driver frame is excluded simply by being absent from the list,
# which is exactly what lets it catch the unwind INTERNALLY (§7.4) — Binaryen forbids pairing
# an only-list with a remove-list, so omission IS the pin. On the no-wasm3 kernel there are no
# suspend points, so this instruments nothing; Phase 5 expands only_list to the real wasm3-op
# functions + the mc_sys_* trampoline (everything from the trampoline UP TO but not including
# the driver frame). The host is never modified; there is no mc_prepare_rewind (§7.7). Adds
# only the optional asyncify_* exports (allowed by §1.2).
asyncify_wasm(
    name = "kernel",
    src = ":kernel_obj",
    # ignore_indirect MUST stay off (slim commit 4e4d3da): wasm3 dispatches op→op and
    # op_CallRawFunction→trampoline via CALL_INDIRECT, and slim proved that ignoring indirect
    # calls "re-entered the pcall import instead of resuming the continuation" — it breaks
    # nested-m3_Call resumption, the core of mc.pcall / loom programmability. The unwind
    # propagates back up the indirect op chain, so those sites must be instrumented (with it on,
    # the unwind cannot cross them and hits an Asyncify-inserted `unreachable` at the first
    # suspend — the stdin-read block).
    ignore_indirect = False,
    # §7.4 internal catch as a REMOVE-list (blacklist), NOT a whitelist. Asyncify instruments
    # EVERY function that can reach a suspend EXCEPT those named here — the future-proof choice
    # for programmability: mc.pcall runs a guest inside a guest (a nested m3_Call, slim 4e4d3da),
    # and any such new suspend path is auto-instrumented. A whitelist would have to re-enumerate
    # the pcall handler + every suspend helper and would SILENTLY break loom on a miss.
    # Excluded:
    #   agent_os_guest_call_boundary — the ONE Asyncify catch: the unwind spills up the whole
    #     wasm3 op chain + raw handlers + nested m3_Calls + the syscall/fuel suspend helpers (all
    #     auto-instrumented) and STOPS here, which calls asyncify_stop_unwind and returns to the
    #     scheduler — the host never sees a suspend, and there is no mc_prepare_rewind.
    #   main.mc_*  — every host-called export, kept OUT of instrumentation so the host boundary
    #     is provably clean (no export can carry an unwind to the host). mc_tick reaches the
    #     guest only THROUGH the catch frame, so it is never on a live unwind anyway.
    # Cost: ignore_indirect=False conservatively marks the VFS/control plane (vtable indirect
    # calls) instrumentable — dead instrumentation (those paths never call start_unwind), a size
    # cost for Phase 8, not a correctness issue. no-creep asserts the excluded set is state 0.
    remove_list = ASYNCIFY_REMOVE_LIST,
    visibility = ["//visibility:public"],
)

# B5 size gate — loose while incomplete, read against the shipped artifact. Tightens
# post-parity; once Asyncify lands it measures the Asyncified wasm (its real cost, §12.2).
size_limit(
    name = "size_limit",
    file = ":kernel",
    max_bytes = KERNEL_MAX_BYTES,
)

# Anchors the kernel in the test graph: asserts the freestanding wasm actually builds.
build_test(
    name = "test",
    targets = [":kernel"],
)

# The import/export-purity and host-instantiate gates (rust_test SOURCES) live under
# //memcontainers/tests/parity:zig_purity_test and :zig_host_instantiate_test — kernel test
# sources do not belong in the kernel package (kernel/rust has no tests/ dir either). The
# build-rule gates below stay here because they are source/artifact checks local to this
# package, like size_limit — they carry no .rs sources.

# ── Asyncify no-creep gate (§7.4, §9, §15.6) ──────────────────────────────────────────
# The §7.4 internal catch is a REMOVE-list, so "no creep" flips to three invariants on the
# SHIPPED wasm + the Asyncify verbose stream: (1) the ONE catch frame still exists as a named
# function to be pinned (an inlined pin silently escapes — and Binaryen does NOT warn on a
# non-matching remove_list entry); (2) no host-callable mc_prepare_rewind export (the host
# never drives Asyncify, §7.7); (3) no host IMPORT becomes a suspend-driver (only the Asyncify
# intrinsics may change state through an import, A4). The end-to-end proof that the catch
# actually fires is //memcontainers/tests/e2e:core_zig (boot_reaches_login_prompt).
filegroup(
    name = "kernel_asyncify_verbose",
    srcs = [":kernel"],
    output_group = "asyncify_verbose",
)

genrule(
    name = "asyncify_no_creep_check",
    srcs = [
        ":kernel",
        ":kernel_asyncify_verbose",
    ],
    outs = ["asyncify_no_creep.ok"],
    cmd = """
set -eu
wasm="$(location :kernel)"
verbose="$(location :kernel_asyncify_verbose)"

# (1) The §7.4 catch frame must EXIST as a named function so the remove_list pin lands. Its
# name lives in the wasm name section ONLY while it is a real, non-inlined function, so a
# binary substring search (grep -a, no disassembler dep) is the existence proof. If a refactor
# inlined agent_os_guest_call_boundary the pin misses, the frame is instrumented, and the guest
# unwind escapes to the host.
if ! grep -aqF 'agent_os_guest_call_boundary' "$$wasm"; then
  echo "FAIL: §7.4 catch frame agent_os_guest_call_boundary is absent from the shipped wasm"
  echo "      name section (inlined/renamed) — the Asyncify remove_list can no longer pin it."
  exit 1
fi

# (2) No host-callable rewind export: the host never drives Asyncify (§7.7, §15.2).
if grep -aqF 'mc_prepare_rewind' "$$wasm"; then
  echo "FAIL: mc_prepare_rewind present in the shipped wasm — the host must never drive Asyncify."
  exit 1
fi

# (3) No host IMPORT may become a suspend-driver; only the Asyncify intrinsics may change state
# via an import. A new state-changing env import would be a host-visible suspend.
viol="$@.viol"
: > "$$viol"
(grep -E "\\[asyncify\\] .* is an import that can change the state" "$$verbose" || true) | while IFS= read -r line; do
  name="$$(printf '%s\\n' "$$line" | sed -E 's/^\\[asyncify\\] (.*) is an import that can change the state.*$$/\\1/')"
  case "$$name" in
    asyncify_*) ;;
    *) echo "$$line" >> "$$viol" ;;
  esac
done
if [ -s "$$viol" ]; then
  echo "FAIL: a non-Asyncify import can change state (a host-visible suspend, §7.4):"
  cat "$$viol"
  exit 1
fi

echo ok > $@
""",
)

build_test(
    name = "asyncify_no_creep_test",
    targets = [":asyncify_no_creep_check"],
)

# ── Scaffold-shape gate (§15.1, §15.7) ───────────────────────────────────────────────
# Mechanically forbids the first attempt's two production sins: a *_smoke/*_probe source
# in the kernel, and an embedded guest fixture / self-test symbol (@embedFile /
# bootSelfCheck) in production code. A violation fails `bazel test`.
genrule(
    name = "scaffold_shape_check",
    srcs = KERNEL_SRCS + ["src/main.zig"],
    outs = ["scaffold_shape.ok"],
    cmd = """
set -eu
viol=0
for f in $(SRCS); do
  case "$$f" in
    *_smoke*|*_probe*) echo "FAIL: smoke/probe source in kernel: $$f (ZIG_KERNEL §15.7)"; viol=1 ;;
  esac
  if grep -q '@embedFile' "$$f"; then echo "FAIL: embedded fixture (@embedFile) in production: $$f (§15.7)"; viol=1; fi
  if grep -q 'bootSelfCheck' "$$f"; then echo "FAIL: self-test symbol (bootSelfCheck) in production: $$f (§15.7)"; viol=1; fi
done
if [ "$$viol" != 0 ]; then exit 1; fi
echo ok > $@
""",
)

build_test(
    name = "scaffold_shape_test",
    targets = [":scaffold_shape_check"],
)
