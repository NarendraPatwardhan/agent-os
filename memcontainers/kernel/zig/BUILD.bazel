load("@rules_zig//zig:defs.bzl", "zig_binary", "zig_configure_binary", "zig_library")
load("@bazel_skylib//rules:build_test.bzl", "build_test")
load("//bazel/tools/size:defs.bzl", "size_limit")

# kernel/zig — the parity-gated Zig kernel from ZIG_KERNEL.md. The Rust kernel remains
# the oracle/default (B7); Zig ships only by matching it on the shared suite. This file
# is the CONCRETE SCAFFOLD (§15.1): the §4.1 module map exists as empty contract-headed
# files, wired into a buildable freestanding wasm, so the implementer fills named blanks
# and never invents structure. Fill order: §13.
#
# WAMR is the in-kernel guest engine. The shipped kernel is the plain wasm32
# object; suspend/resume is driven by WAMR exec_env re-entry, not a Binaryen pass.
#
# WHAT IS DELIBERATELY NOT HERE YET (cherry-picked from agent-os-slim in Phase order, §15.5):
#   - the generated ctl_zig/env_zig/mc_zig deps — added to kernel_raw as control.zig /
#     bridge.zig / syscall.zig get filled (constants_zig is used from day one).

# Loose scaffold ceiling; tightened after parity, not before (B5).
KERNEL_MAX_BYTES = 1024 * 1024

# The §4.1 module map, declared EXPLICITLY (never globbed): the scaffold-shape gate below
# asserts this set carries no *_smoke/*_probe/fixture file (§15.7). Adding a source here is
# a reviewed act — that is the anti-sprawl mechanism the first attempt lacked.
KERNEL_SRCS = [
    "src/state.zig",
    "src/console.zig",
    "src/control.zig",
    "src/control/wire.zig",
    "src/control/buf.zig",
    "src/control/fs.zig",
    "src/control/exec.zig",
    "src/control/svc.zig",
    "src/bridge.zig",
    "src/boot.zig",
    "src/task.zig",
    "src/scheduler.zig",
    "src/guest.zig",
    "src/guest/pcall.zig",
    "src/wamr/alloc.zig",
    "src/wamr/bindings.zig",
    "src/rescue.zig",
    "src/syscall.zig",
    "src/syscall/mem.zig",
    "src/syscall/fd.zig",
    "src/syscall/fsops.zig",
    "src/syscall/proc.zig",
    "src/syscall/ambient.zig",
    "src/syscall/net.zig",
    "src/syscall/ns.zig",
    "src/syscall/svc.zig",
    "src/vfs.zig",
    "src/errno.zig",
    "src/wasm_sections.zig",
    "src/ipc/pipe.zig",
    "src/egress/net.zig",
    "src/egress/host_call.zig",
    "src/egress/persist.zig",
    "src/service/activation.zig",
    "src/service/registry.zig",
    "src/fs/memfs.zig",
    "src/fs/tarfs.zig",
    "src/fs/cowfs.zig",
    "src/fs/overlayfs.zig",
    "src/fs/devfs.zig",
    "src/fs/envfs.zig",
    "src/fs/procfs.zig",
    "src/fs/netfs.zig",
    "src/fs/persistfs.zig",
    "src/fs/servedfs.zig",
    "src/fs/servicefs.zig",
    "src/fs/mountfs.zig",
    "src/fs/toolsfs.zig",
    "src/fs/proxy.zig",
    "src/fs/utils.zig",
]

# The embedded WAMR interpreter foundation (PERFORMANCE.md §8), compiled freestanding by zig cc
# into the kernel. Its libc/platform surface is satisfied in-module
# (third_party/wamr/freestanding), never as a new host import (A4, verified by import-purity).
WAMR_CSRC = [
    "//third_party/wamr:freestanding_libc",
    "//third_party/wamr:freestanding_platform",
    "@wamr//:core_srcs",
]
WAMR_EXTRA_SRCS = [
    "//third_party/wamr:freestanding_headers",
    "@wamr//:headers",
]
WAMR_COPTS = [
    "-O3",
    "-fvisibility=hidden",
    "-DWASM_RUNTIME_API_EXTERN=",
    "-DWASM_API_EXTERN=",
    "-DWASM_ENABLE_INTERP=1",
    "-DWASM_ENABLE_FAST_INTERP=1",
    "-DWASM_ENABLE_INSTRUCTION_METERING=1",
    "-DWASM_ENABLE_AOT=0",
    "-DWASM_ENABLE_JIT=0",
    "-DWASM_ENABLE_FAST_JIT=0",
    "-DWASM_ENABLE_THREAD_MGR=0",
    "-DWASM_ENABLE_SHARED_MEMORY=0",
    "-DWASM_ENABLE_LIBC_WASI=0",
    "-DWASM_ENABLE_LIBC_BUILTIN=0",
    "-DWASM_ENABLE_MULTI_MODULE=0",
    "-DWASM_ENABLE_GC=0",
    "-DWASM_ENABLE_BULK_MEMORY=1",
    "-DWASM_ENABLE_REF_TYPES=1",
    "-DBH_MALLOC=wasm_runtime_malloc",
    "-DBH_FREE=wasm_runtime_free",
    "-Ithird_party/wamr/freestanding/include",
    "-fdata-sections",
    "-ffunction-sections",
    "-fvisibility=hidden",
]

zig_library(
    name = "wamr_bindings",
    main = "src/wamr/bindings.zig",
    import_name = "wamr_bindings",
    visibility = ["//third_party/wamr:__pkg__"],
)

# The reactor module: exports only, no _start. Reachable files compile; the rest are
# declared inputs the fill phases import as they land (§15.1). Tagged manual — it is only
# meaningful under the wasm transition (building it for the host has no entry point).
zig_binary(
    name = "kernel_raw",
    main = "src/main.zig",
    srcs = KERNEL_SRCS,
    copts = WAMR_COPTS,
    csrcs = WAMR_CSRC,
    extra_srcs = WAMR_EXTRA_SRCS,
    linkopts = [
        "-fno-entry",
        "-rdynamic",
    ],
    tags = ["manual"],
    deps = [
        "//memcontainers/contracts:constants_zig",  # errno/caps/tiers/flags (B2)
        "//memcontainers/contracts:env_zig",  # bridge.zig derives the env extern surface from IMPORTS (§5.1)
        "//memcontainers/contracts:mc_zig",  # generated syscall descriptors + Pending union (§5.1)
        "//memcontainers/contracts:ctl_zig",  # generated control EXPORTS descriptor — main.zig's export-purity gate (§5.2)
        "//memcontainers/shcore:shcore",
        "@wamr//:incs",  # WAMR include path for the freestanding C compile
        # ctl_zig feeds main.zig's control-export purity gate (its EXPORTS descriptor, data-only and
        # lazily analyzed — no decoder is pulled in). control.zig still hand-encodes the control-frame
        # wire codec against control.kdl rather than consuming ctl.gen.zig's generated codecs; doing so
        # first needs the projector to emit leaner Zig so those decoders link into the kernel.
    ],
)

# Transition to wasm32-freestanding, size-optimised — the exact lane every kernel/guest uses.
zig_configure_binary(
    name = "kernel_obj",
    actual = ":kernel_raw",
    mode = "release_small",
    tags = ["manual"],
    target = "//platforms:wasm32_freestanding",
    threaded = "single",  # the kernel is cooperative/single-threaded (A7); enables WasmAllocator
)

# The shipped kernel artifact every consumer data-depends on (B1). WAMR suspend/resume
# is handled inside the embedded engine, so the shipped artifact is the configured
# wasm32 object directly.
alias(
    name = "kernel",
    actual = ":kernel_obj",
    visibility = ["//visibility:public"],
)

# B5 size gate — loose while incomplete, read against the shipped artifact.
size_limit(
    name = "size_limit",
    file = ":kernel",
    max_bytes = KERNEL_MAX_BYTES,
)

# Anchors the kernel in the test graph: asserts the freestanding wasm actually builds.
build_test(
    name = "test",
    targets = [":kernel"],
)

# ── Scaffold-shape gate (§15.1, §15.7) ───────────────────────────────────────────────
# Mechanically forbids the first attempt's two production sins: a *_smoke/*_probe source
# in the kernel, and an embedded guest fixture / self-test symbol (@embedFile /
# bootSelfCheck) in production code. A violation fails `bazel test`.
genrule(
    name = "scaffold_shape_check",
    srcs = KERNEL_SRCS + ["src/main.zig"],
    outs = ["scaffold_shape.ok"],
    cmd = """
set -eu
viol=0
for f in $(SRCS); do
  case "$$f" in
    *_smoke*|*_probe*) echo "FAIL: smoke/probe source in kernel: $$f (ZIG_KERNEL §15.7)"; viol=1 ;;
  esac
  if grep -q '@embedFile' "$$f"; then echo "FAIL: embedded fixture (@embedFile) in production: $$f (§15.7)"; viol=1; fi
  if grep -q 'bootSelfCheck' "$$f"; then echo "FAIL: self-test symbol (bootSelfCheck) in production: $$f (§15.7)"; viol=1; fi
done
if [ "$$viol" != 0 ]; then exit 1; fi
echo ok > $@
""",
)

build_test(
    name = "scaffold_shape_test",
    targets = [":scaffold_shape_check"],
)
