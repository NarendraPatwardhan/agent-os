load("@rules_rust//rust:defs.bzl", "rust_binary")
load("//bazel:mc_program.bzl", "mc_rust_program")

# programs/examples/crashloop — /bin/crashloop, a deliberately-broken resident service used ONLY by the
# kv-test e2e: in SERVICE mode it crashes before `svc_serve`, so a `svc_connect` to it exercises the
# kernel's bounded activation-failure path (codex #4 — re-activate a few times, then EIO, never spin
# forever). Allocator-free, imports ONLY `mc`; built under --platforms=//platforms:wasm32_freestanding.
rust_binary(
    name = "crashloop_bin",
    srcs = ["src/main.rs"],
    crate_root = "src/main.rs",
    edition = "2021",
    tags = ["manual"],
    deps = [
        "//memcontainers/sysroot/rust:lib",
    ],
)

# /bin/crashloop — stamped (tier + service) + attested from the build graph (mc_rust_program).
mc_rust_program(
    name = "crashloop",
    lib = ":crashloop_bin",
    tier = "isolated",
    service = "crashloop",
    visibility = ["//visibility:public"],
)
