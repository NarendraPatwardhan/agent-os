load("@rules_zig//zig:defs.bzl", "zig_binary", "zig_configure_binary", "zig_library")
load("//bazel:mc_program.bzl", "cc_object", "mc_program")
load("//bazel/tools/size:defs.bzl", "size_limit")

cc_object(name = "wasi_adapter_link", obj = "//memcontainers/wasi-adapter:wasi_adapter_staticlib")

zig_library(
    name = "registry_lib",
    main = "//memcontainers/programs/syntax/grammars:syntax_registry_zig",
    import_name = "syntax_registry",
    deps = ["//memcontainers/contracts:syntax_zig"],
)

zig_binary(
    name = "syntax_raw",
    main = "entry.zig",
    srcs = ["scanner.zig"],
    csrcs = [
        "@tree_sitter//:runtime_c",
        "//memcontainers/wasi-adapter:close_shim.c",
        "//memcontainers/programs/syntax/grammars:syntax_pack_csrcs",
    ],
    extra_srcs = [
        "@tree_sitter//:runtime_support",
    ],
    linkopts = ["-lc"],
    deps = [
        "@tree_sitter//:runtime_headers",
        "//memcontainers/contracts:syntax_zig",
        "//memcontainers/sysroot/zig:mc",
        "//memcontainers/sysroot/zig:svc",
        "//memcontainers/sysroot/zig:sys",
        ":registry_lib",
        ":wasi_adapter_link",
    ],
    tags = ["manual"],
)

zig_configure_binary(
    name = "syntax_wasm",
    actual = ":syntax_raw",
    mode = "release_small",
    threaded = "single",
    target = "//platforms:wasm32_wasi",
    tags = ["manual"],
)

mc_program(
    name = "syntax",
    wasm = ":syntax_wasm",
    tier = "isolated",
    service = "syntax",
    mem = 256 * 1024 * 1024,
    fuel = 1000000000000,
    table = 20000,
    visibility = ["//visibility:public"],
)

# Native semantic tables and the shared Lua-family parser pack make this a meaningful regression
# boundary: growth must be explained by parser or service capability, not regenerated table drift.
size_limit(
    name = "size_limit",
    file = ":syntax_opt",
    max_bytes = 400000,
)
