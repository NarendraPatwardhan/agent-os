family lua.core "1.0.0"

fragment separated(item, separator) = (item (separator item)*)?
fragment separated1(item, separator) = item (separator item)*

skip whitespace | line_comment | long_comment
external long_string_start | long_string_content | long_string_end | long_comment
word identifier

token whitespace = /[\t\n\r ]+/
token line_comment = "--" /[^\n\r]*/
  => comment
token identifier = /[A-Za-z_][A-Za-z0-9_]*/
  => identifier
token number = /(0[xX][0-9A-Fa-f]+(\.[0-9A-Fa-f]*)?([pP][+-]?[0-9]+)?|[0-9]+(\.[0-9]*)?([eE][+-]?[0-9]+)?|\.[0-9]+([eE][+-]?[0-9]+)?)/
  => literal
token quoted_string = /"([^"\\\n\r]|\\.)*"|'([^'\\\n\r]|\\.)*'/
  => literal

slot type_annotation
slot return_type_annotation

lua_family_unit = body:_statement*
  => module(body)
     derives scope

open _statement =
  | empty_statement
  | assignment_statement
  | local_declaration
  | function_declaration
  | local_function_declaration
  | function_call
  | do_statement
  | while_statement
  | repeat_statement
  | if_statement
  | for_numeric_statement
  | for_generic_statement
  | return_statement
  | break_statement
  | goto_statement
  | label_statement

empty_statement = ";"

assignment_statement = left:separated1(variable, ",") "=" right:separated1(_expression, ",")
  => assignment(left, right)

local_declaration = "local" separated1(local_name, ",") ("=" separated1(_expression, ","))?
local_name = name:identifier type_annotation?

function_declaration =
  "function" name:function_name parameters:parameters return_type_annotation? body:block? "end"
  => function(name, parameters, body)
     derives declaration, scope

local_function_declaration =
  "local" "function" name:identifier parameters:parameters return_type_annotation? body:block? "end"
  => function(name, parameters, body)
     derives declaration, scope

function_name = identifier ("." identifier)* (":" identifier)?
parameters = "(" separated(parameter, ",") (","? "..." type_annotation?)? ")"

parameter = name:identifier type_annotation?
  => parameter(name)
     derives declaration

block = body:_statement+
  => block(body)
     derives scope

do_statement = "do" body:block? "end"

while_statement = "while" condition:_expression "do" body:block? "end"
  => loop(condition, body)

repeat_statement = "repeat" body:block? "until" condition:_expression
  => loop(condition, body)

if_statement = "if" condition:_expression "then" body:block? elseif_clause* else_clause? "end"
  => branch(condition, body)

elseif_clause = "elseif" condition:_expression "then" body:block?
else_clause = "else" body:block?

for_numeric_statement =
  "for" name:identifier "=" start:_expression "," end:_expression ("," step:_expression)? "do"
  body:block? "end"

for_generic_statement =
  "for" name:separated1(identifier, ",") "in" value:separated1(_expression, ",") "do" body:block?
  "end"

return_statement = right 0: "return" value:separated1(_expression, ",")? ";"?
  => return(value)

break_statement = "break"
goto_statement = "goto" name:identifier
label_statement = "::" name:identifier "::"

open _expression =
  | nil
  | boolean
  | number
  | quoted_string
  | long_string
  | vararg_expression
  | function_expression
  | table_constructor
  | variable
  | function_call
  | parenthesized_expression
  | unary_expression
  | binary_expression

nil = "nil"
boolean = "true" | "false"

long_string = long_string_start long_string_content* long_string_end
  => literal

vararg_expression = "..."

function_expression = "function" parameters:parameters return_type_annotation? body:block? "end"
  => function(parameters, body)
     derives scope

parenthesized_expression = "(" _expression ")"

prefix unary_expression over _expression
  => operator(right=argument)
  right 12: "not" | "#" | "-" | "~"

infix binary_expression over _expression
  => operator(left, right)
  left   1: "or"
  left   2: "and"
  left   3: "<" | ">" | "<=" | ">=" | "~=" | "=="
  left   4: "|"
  left   5: "~"
  left   6: "&"
  left   7: "<<" | ">>"
  right  8: ".."
  left   9: "+" | "-"
  left  10: "*" | "/" | "//" | "%"
  right 13: "^"

variable = identifier | index_expression | member_expression
index_expression = left 14: receiver:_prefix_expression "[" index:_expression "]"

member_expression = left 14: receiver:_prefix_expression "." name:identifier
  => member(receiver, name)

open _prefix_expression =
  | identifier
  | parenthesized_expression
  | function_call
  | index_expression
  | member_expression

function_call = left 15: callee:_prefix_expression (":" method:identifier)? arguments:arguments
  => call(callee, arguments)

arguments = "(" separated(_expression, ",") ")" | table_constructor | quoted_string | long_string

table_constructor = "{" separated(field_entry, ",") ","? "}"
  => table

field_entry =
  | "[" name:_expression "]" "=" value:_expression
  | name:identifier "=" value:_expression
  | value:_expression
  => field(name, value)

map long_comment => comment

conflict variable function_call
conflict _prefix_expression _statement
conflict _prefix_expression variable
conflict _expression _prefix_expression
conflict table_constructor block
