grammar luau "0.725.0"

use lua.core
start source_file

source_file = body:_statement*
  => module(body)
     derives scope

extend _statement =
  | type_alias_declaration
  | exported_type_alias_declaration
  | compound_assignment_statement
  | continue_statement

extend _expression = if_expression | type_cast_expression | interpolated_string

fill type_annotation = ":" type:type_expression
fill return_type_annotation = ":" return_type:type_expression

type_alias_declaration = "type" name:identifier type_parameters? "=" value:type_expression
  => declaration(name)
     derives declaration

exported_type_alias_declaration = "export" type_alias_declaration
type_parameters = "<" separated1(type_parameter, ",") ">"
type_parameter = name:identifier ("=" value:type_expression)?

type_expression =
  | identifier
  | "nil"
  | "boolean"
  | "number"
  | "string"
  | "thread"
  | "buffer"
  | "any"
  | "unknown"
  | "never"
  | singleton_type
  | table_type
  | function_type
  | union_type
  | intersection_type
  | optional_type
  | generic_type
  | typeof_type
  => type

singleton_type = quoted_string | "true" | "false"
table_type = "{" (separated1(type_field, ",") ","?)? "}"

type_field =
  | name:identifier ":" value:type_expression
  | "[" name:type_expression "]" ":" value:type_expression
  | value:type_expression

function_type = right 1: type_parameters? "(" separated(type_expression, ",") ")" "->" return_type:type_expression
  => type

union_type = left 1: left:type_expression "|" right:type_expression
intersection_type = left 2: left:type_expression "&" right:type_expression
optional_type = left 3: type_expression "?"
generic_type = left 4: identifier "<" separated1(type_expression, ",") ">"
typeof_type = "typeof" "(" _expression ")"

compound_assignment_statement =
  left:variable operator:("+=" | "-=" | "*=" | "/=" | "//=" | "%=" | "^=" | "..=") right:_expression
  => assignment(left, right)

continue_statement = "continue"

if_expression = right 1: "if" condition:_expression "then" consequence:_expression "else" alternative:_expression
  => branch(condition, body=consequence)

type_cast_expression = left 11: value:_expression "::" type:type_expression
  => operator(left=value)

token interpolated_string = "`" /([^`\\]|\\.)*/ "`"
  => literal

conflict type_expression _expression
conflict table_type table_constructor
