load("//bazel:mc_grammar.bzl", "mc_grammar", "mc_syntax_pack")

package(default_visibility = ["//visibility:public"])

exports_files([
    "lua.grammar",
    "luau.grammar",
    "families/lua-core.grammar",
])

sh_test(
    name = "format_test",
    srcs = ["format_test.sh"],
    args = [
        "$(location //bazel/tools/mc-grammar-gen:mc-grammar-fmt)",
        "--check",
        "$(location :families/lua-core.grammar)",
        "$(location :lua.grammar)",
        "$(location :luau.grammar)",
    ],
    data = [
        ":families/lua-core.grammar",
        ":lua.grammar",
        ":luau.grammar",
        "//bazel/tools/mc-grammar-gen:mc-grammar-fmt",
    ],
)

mc_grammar(
    name = "lua",
    root = "lua.grammar",
    modules = {"families/lua-core.grammar": "lua.core"},
    language = "lua",
)

mc_syntax_pack(
    name = "syntax_pack",
    grammars = [
        ":lua",
        ":luau",
    ],
)

filegroup(name = "syntax_pack_csrcs", srcs = [":syntax_pack"], output_group = "csrcs")
filegroup(name = "syntax_registry_zig", srcs = [":syntax_pack"], output_group = "registry_zig")
filegroup(name = "syntax_node_types", srcs = [":syntax_pack"], output_group = "node_types")
filegroup(name = "syntax_manifests", srcs = [":syntax_pack"], output_group = "manifests")
filegroup(name = "syntax_pack_report", srcs = [":syntax_pack"], output_group = "report")

mc_grammar(
    name = "luau",
    root = "luau.grammar",
    modules = {"families/lua-core.grammar": "lua.core"},
    language = "luau",
)
