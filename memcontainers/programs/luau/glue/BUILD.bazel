load("@bazel_skylib//rules:build_test.bzl", "build_test")
load("@rules_zig//zig:defs.bzl", "zig_binary", "zig_configure_binary", "zig_library")
load("//bazel:mc_program.bzl", "cc_headers", "cc_object", "mc_program")

exports_files(
    ["lib/browser.luau"],
    visibility = ["//memcontainers/programs/browser:__pkg__"],
)

# The Luau glue, written in ZIG (the C/C++ → Zig rewrite, SYSTEMS.md). The patched upstream Luau
# (C++, fetched by the @luau http_archive) links against this. trap + the mc syscall shim are
# self-contained (no Lua C API); the bindings (sys/stdlib + json/hash/re/encoding/deflate + the
# entry) @cImport Luau's Lua C API from @luau. The C/C++ headers (trap.h, error_channel.h) are
# #included by the patched Luau source. See third_party/luau/SYSTEM.md.

# trap + mc — the kernel-trap-unwind primitives over the mc_sys_pcall / mc_sys_set_throw imports. No
# Lua C API, so this compiles standalone (a foundation compile-check, gated below).
zig_library(
    name = "trap",
    main = "trap.zig",
    visibility = ["//visibility:public"],
    deps = ["//memcontainers/sysroot/zig:mc"],
)

build_test(
    name = "trap_build_test",
    targets = [":trap"],
)

# The full glue library: trap + the sys/stdlib bindings (which @cImport the Lua C API). Linked into
# the luau binary; its export fns (mc_protected_call, mc_open_sys, …) resolve the patched Luau C++ +
# entry.zig. cdeps brings @luau's headers so the bindings' @cImport "lua.h" resolves.
zig_library(
    name = "glue",
    # In lockstep with :luau_raw's srcs (minus entry.zig, the binary's main) so this gate compiles
    # exactly what the binary compiles.
    srcs = [
        "deflate.zig",
        "encoding.zig",
        "fs.zig",
        "hash.zig",
        "json.zig",
        "lua.zig",
        "re.zig",
        "stdlib.zig",
        "sys.zig",
        "trap.zig",
        "wasi_shim.zig",
    ],
    extra_srcs = glob(["lib/*.luau"]),  # @embedFile'd by stdlib.zig
    main = "glue.zig",
    visibility = ["//visibility:public"],
    deps = [
        "//memcontainers/contracts:constants_zig",
        "//memcontainers/sysroot/zig:mc",  # the shared mc syscall ABI (was a co-located mc.zig)
        "@luau//:interp_headers",
    ],
)

# Compile-gate the glue (trap + sys + stdlib + the Lua C API @cImport) in `bazel test //...`. The
# luau binary itself is `manual` (a large C++ build), so this keeps the Zig glue honest on every run.
build_test(
    name = "glue_build_test",
    targets = [":glue"],
)

# The wasi→mc adapter as a SELF-CONTAINED staticlib, link-injected into luau (see :luau_raw deps).
# luau is not a Rust crate, so it links the staticlib (which bundles the core funcs + panic_handler)
# rather than the bare object the rust mc_box uses.
cc_object(
    name = "wasi_adapter_link",
    obj = "//memcontainers/wasi-adapter:wasi_adapter_staticlib",
)

# Puts this dir (trap.h, error_channel.h — #included by the patched Luau source) on the build's -I
# path. INCLUDE-ONLY (no hdrs): error_channel.h is C++ (<new>), so it must NOT become an @cImport
# direct_public_header. The header FILES reach the csrcs compile via the binary's extra_srcs.
cc_headers(
    name = "glue_incs",
    hdrs = [],
    includes = ["."],
    visibility = ["//visibility:public"],
)

# /bin/luau — `zig c++` compiles the patched upstream Luau (VM/Compiler/Ast/Bytecode/Common from
# @luau) + the Zig glue + entry.zig into a wasm32-wasi guest. -fno-exceptions/-fno-rtti: the EH is
# kernel-mediated via the trap glue. (The wasi-adapter conversion to mc + the budget/tier/service
# stamping + the import verify are layered on next.) See third_party/luau/SYSTEM.md.
zig_binary(
    name = "luau_raw",
    srcs = [
        "deflate.zig",
        "encoding.zig",
        "fs.zig",
        "hash.zig",
        "json.zig",
        "lua.zig",
        "re.zig",
        "stdlib.zig",
        "sys.zig",
        "trap.zig",
        "wasi_shim.zig",
    ],
    copts = [
        # Force Luau's public C API to extern "C" so the Zig entry's C-mode @cImport links it (else
        # the API is C++-mangled, resolves to `env` imports, and the VM is dead-stripped).
        "-include",
        "memcontainers/programs/luau/glue/force_extern_c.h",
        "-fno-exceptions",
        "-fno-rtti",
    ],
    csrcs = ["@luau//:interp_srcs"],
    extra_srcs = glob(["lib/*.luau"]) + [
        # the .luau batteries, @embedFile'd by stdlib.zig
        "@luau//:interp_all_hdrs",
        "error_channel.h",
        "force_extern_c.h",
        "trap.h",
    ],
    # -lc / -lc++ reach the global zig build args (zig_build.bzl:500), enabling wasi-libc + libc++
    # for the csrcs compile (Luau #includes <string.h>, <cstdint>, <vector>, …) AND making argv
    # available (Args.zig:17-19), without cc_common.link (which would demand a CC toolchain we don't
    # register).
    linkopts = [
        "-lc",
        "-lc++",
        # The kernel's trap-unwind re-enters the guest via __mc_pcall_run and reads __stack_pointer
        # (kernel/rust/src/wasm/mod.rs); without these EXPORTED, --gc-sections drops __mc_pcall_run
        # (it's called only from outside) and lua_pcall can't unwind. memcontainers' xtask did the same.
        "--export=__mc_pcall_run",
        "--export=__stack_pointer",
    ],
    main = "entry.zig",
    tags = ["manual"],
    deps = [
        "@luau//:interp_headers",
        "//memcontainers/contracts:constants_zig",
        "//memcontainers/sysroot/zig:mc",  # the shared mc syscall ABI (was a co-located mc.zig)
        # The wasi→mc adapter, FORCE-LINKED as an object (cc_object): its __imported_wasi_* defs
        # override wasi-libc's import stubs, converting luau's wasi imports (fd_write, args_get, …)
        # to mc syscalls → a pure-mc guest. luau's wasi names are stable (zig wasi-libc), so one
        # link converges (no trampoline rounds, unlike the rust mc_box).
        ":wasi_adapter_link",
        ":glue_incs",
    ],
)

zig_configure_binary(
    name = "luau_wasm",
    actual = ":luau_raw",
    mode = "release_small",
    tags = ["manual"],
    target = "//platforms:wasm32_wasi",
    # wasm is single-threaded — std.heap.c_allocator's WasmAllocator is only implemented for
    # -fsingle-threaded (else @compileError("unimplemented")).
    threaded = "single",
    visibility = ["//visibility:public"],
)

# /bin/luau — the load-ready guest: the wasm32-wasi build stamped with its mc_tier (full) + mc_budget
# (256 MiB · 2T fuel · 40k table, SYSTEMS.md section 4.3) custom sections the kernel reads at exec.
mc_program(
    name = "luau",
    fuel = 2000000000000,
    mem = 256 * 1024 * 1024,
    table = 40000,
    tier = "full",
    visibility = ["//visibility:public"],
    wasm = ":luau_wasm",
)

# /bin/luau-analyze — the Luau type checker (SYSTEMS.md section 10.3). Same zig c++ recipe as luau, but the csrcs are
# Ast + Common + Config + Analysis (no VM/Compiler — it never executes), the C++ entry is
# analyze_main.cpp (a holdout: int-main-renamed mc_analyze_run that analyze_entry.zig forwards to),
# and analysis_eh_shim.h is force-included into every Analysis TU (the type checker's throw sites are
# patched to mc_analysis_abort, its try/catch neutralized — Luau type errors are DATA, not
# exceptions). The Ast Parser still routes parse errors through the trap, so trap.zig + the
# __mc_pcall_run/__stack_pointer exports are kept.
zig_binary(
    name = "luau_analyze_raw",
    srcs = [
        "trap.zig",
        "wasi_shim.zig",
    ],
    copts = [
        # Force-include the analysis EH shim into every TU (mc_analysis_abort + try/catch neutralize).
        "-include",
        "memcontainers/programs/luau/glue/analysis_eh_shim.h",
        "-fno-exceptions",
        "-fno-rtti",
    ],
    csrcs = [
        "@luau//:analyze_srcs",
        "analyze_main.cpp",
    ],
    extra_srcs = [
        "@luau//:analysis_all_hdrs",
        "@luau//:interp_all_hdrs",
        "analysis_eh_shim.h",
        "error_channel.h",
        "trap.h",
    ],
    linkopts = [
        "-lc",
        "-lc++",
        "--export=__mc_pcall_run",
        "--export=__stack_pointer",
    ],
    main = "analyze_entry.zig",
    tags = ["manual"],
    deps = [
        ":glue_incs",
        ":wasi_adapter_link",
        "//memcontainers/sysroot/zig:mc",  # the shared mc syscall ABI (via trap.zig)
        "@luau//:analysis_incs",
        "@luau//:interp_incs",
    ],
)

zig_configure_binary(
    name = "luau_analyze_wasm",
    actual = ":luau_analyze_raw",
    mode = "release_small",
    tags = ["manual"],
    target = "//platforms:wasm32_wasi",
    threaded = "single",
    visibility = ["//visibility:public"],
)

# luau-analyze's budget: 256 MiB · 400B fuel (type inference is bounded, not a runtime) · 40k table.
mc_program(
    name = "luau-analyze",
    fuel = 400000000000,
    mem = 256 * 1024 * 1024,
    table = 40000,
    tier = "full",
    visibility = ["//visibility:public"],
    wasm = ":luau_analyze_wasm",
)
