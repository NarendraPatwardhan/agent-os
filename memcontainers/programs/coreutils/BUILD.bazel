load("//bazel:coreutils.bzl", "coreutils_box")

# programs/coreutils — Zig nutils-derived multicall boxes, pure mc from source. The target names stay
# compatible with the former Rust lane so images and mc-roster consumers can flip without label churn.

COREUTILS_SRCS = glob(
    ["src/**/*.zig"],
    exclude = [
        "src/build_options/*.zig",
        "src/main.zig",
    ],
)

_TIERS = {
    "isolated": "isolated",
    "readonly": "read-only",
    "readwrite": "read-write",
    "full": "full",
}

_SETS = {
    "": "full",
    "min-": "min",
}

[
    coreutils_box(
        name = "mcbox-" + infix + tier,
        tier = tier,
        tier_section = tier_section,
        set_kind = set_kind,
        srcs = COREUTILS_SRCS,
    )
    for tier, tier_section in _TIERS.items()
    for infix, set_kind in _SETS.items()
]
