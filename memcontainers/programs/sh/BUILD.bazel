load("@rules_rust//rust:defs.bzl", "rust_binary")
load("//bazel:mc_program.bzl", "mc_rust_program")

# programs/sh — /bin/sh, the guest shell. A no_std wasm32-freestanding binary that runs the
# OS-agnostic //memcontainers/shcore engine over //memcontainers/sysroot's mc syscalls. It is NOT part of the mcbox multicall
# (SYSTEMS.md): it spawns the coreutils boxes, drives pipelines/redirections/job control, and
# boots as pid 1 (the login shell). Three modes — interactive REPL, `sh -c COMMAND`, and
# `sh FILE ARGS`. Ported from memcontainers crates/programs/src/bin/sh.rs. Being sysroot-native it
# imports ONLY `mc` (no WASI, no conversion); built under --platforms=//platforms:wasm32_freestanding.
rust_binary(
    name = "sh_bin",
    srcs = glob(["src/**/*.rs"]),
    crate_root = "src/main.rs",
    edition = "2021",
    tags = ["manual"],
    deps = [
        "//memcontainers/shcore",  # the OS-agnostic shell engine (parser/expand/exec over the ShellOs trait)
        "//memcontainers/sysroot/rust",  # mc syscall wrappers + the _start/panic_handler runtime
        "@crates//:talc",  # the no_std wasm linear-memory allocator (same as the kernel, A8)
    ],
)

# /bin/sh — stamped (tier) + attested from the build graph, not the source (mc_rust_program). full
# tier: it spawns the coreutils boxes, fetches via pkgfsd, and drives job control.
mc_rust_program(
    name = "sh",
    lib = ":sh_bin",
    tier = "full",
    visibility = ["//visibility:public"],
)
