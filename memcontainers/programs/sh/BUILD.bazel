load("@rules_zig//zig:defs.bzl", "zig_binary", "zig_configure_binary")
load("//bazel:mc_program.bzl", "mc_program")

# programs/sh — /bin/sh, the Zig guest shell over canonical
# //memcontainers/shcore:lib and //memcontainers/sysroot/zig:sys. It is
# freestanding and imports only `mc`; no WASI adapter and no Rust/C interop.
zig_binary(
    name = "sh_raw",
    linkopts = [
        "-fno-entry",
        "-rdynamic",
    ],
    main = "src/main.zig",
    tags = ["manual"],
    deps = [
        "//memcontainers/contracts:shell_zig",
        "//memcontainers/shcore:lib",
        "//memcontainers/sysroot/zig:sys",
    ],
)

zig_configure_binary(
    name = "sh_wasm",
    actual = ":sh_raw",
    mode = "release_small",
    tags = ["manual"],
    target = "//platforms:wasm32_freestanding",
    threaded = "single",
)

mc_program(
    name = "sh",
    tier = "full",
    visibility = ["//visibility:public"],
    wasm = ":sh_wasm",
)
