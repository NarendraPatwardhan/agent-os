// contracts/control.kdl — the `mc_ctl_*` CONTROL boundary (host → kernel).
//
// The typed channel a host uses to drive and inspect a running kernel: boot, tick,
// feed input, and read/write the VFS out-of-band (for image staging, snapshots, and
// the server's exec jobs). memcontainers grew this organically and zmc's was ad hoc;
// agent-os elevates it to a generated contract — the biggest structural upgrade that
// makes the two kernels interchangeable (§4.2). Transcribed from memcontainers
// crates/kernel/src/lib.rs `pub extern "C" fn mc_*`.
//
// These are kernel EXPORTS (the host imports them). The projector emits the kernel's
// `#[unsafe(no_mangle)] extern "C"` signatures and the Rust + JS host bindings.
//
// Scratch-buffer protocol: a host sizes a shared buffer via mc_ctl_buf(len) -> ptr,
// writes its request there, calls an op (which returns a byte length or a negative
// errno), then reads results back from mc_ctl_buf(0). Paths/data are passed as
// (ptr,len) regions into that buffer.
//
// Shape: `export "<name>" group="<group>" { arg "<n>" type="<t>"; ... ret "<t>"; doc "..." }`.

// ── lifecycle / hot path (§4.4) ──────────────────────────────────────────────
export "mc_init"   group="lifecycle" { ret "i32"; doc "Boot the kernel (load base image, start pid 1). 0 on success." }
export "mc_tick"   group="lifecycle" { ret "i32"; doc "Run one bounded slice of kernel work. The host drives this loop; the kernel never blocks it." }
export "mc_input"  group="lifecycle" { arg "ptr" type="cptr"; arg "len" type="len"; ret "void"; doc "Feed len bytes of terminal input to the foreground task." }
export "mc_resize" group="lifecycle" { arg "cols" type="i32"; arg "rows" type="i32"; ret "void"; doc "Notify the kernel of a terminal resize." }

// ── shared scratch buffer ────────────────────────────────────────────────────
export "mc_ctl_buf" group="buffer" { arg "len" type="len"; ret "mptr"; doc "Resize the control scratch buffer to len and return its pointer; mc_ctl_buf(0) returns the current pointer for reading results." }

// ── out-of-band VFS access (image staging, snapshot inspection) ──────────────
export "mc_ctl_read"    group="vfs" { arg "path_ptr" type="u32"; arg "path_len" type="u32"; ret "i32"; doc "Read file `path` into the scratch buffer; byte length or negative errno." }
export "mc_ctl_write"   group="vfs" { arg "path_ptr" type="u32"; arg "path_len" type="u32"; arg "data_ptr" type="u32"; arg "data_len" type="u32"; ret "i32"; doc "Write data to file `path`; 0 or negative errno." }
export "mc_ctl_readdir" group="vfs" { arg "path_ptr" type="u32"; arg "path_len" type="u32"; ret "i32"; doc "List directory `path` into the scratch buffer; byte length or negative errno." }
export "mc_ctl_stat"    group="vfs" { arg "path_ptr" type="u32"; arg "path_len" type="u32"; ret "i32"; doc "Stat `path` into the scratch buffer; byte length or negative errno." }
export "mc_ctl_mkdir"   group="vfs" { arg "path_ptr" type="u32"; arg "path_len" type="u32"; ret "i32"; doc "Create directory `path`." }
export "mc_ctl_unlink"  group="vfs" { arg "path_ptr" type="u32"; arg "path_len" type="u32"; ret "i32"; doc "Remove the file at `path`." }
export "mc_ctl_symlink" group="vfs" { arg "target_ptr" type="u32"; arg "target_len" type="u32"; arg "link_ptr" type="u32"; arg "link_len" type="u32"; ret "i32"; doc "Create symlink `link` → `target` (two-region layout)." }
export "mc_ctl_mount"   group="vfs" { arg "path_ptr" type="u32"; arg "path_len" type="u32"; arg "read_only" type="i32"; ret "i32"; doc "Mount a host-backed driver at `path`." }
export "mc_ctl_unmount" group="vfs" { arg "path_ptr" type="u32"; arg "path_len" type="u32"; ret "i32"; doc "Unmount the driver at `path`." }

// ── host-driven exec jobs (the server's command channel) ─────────────────────
// Start a detached `/bin/sh -c` job, then poll/peek its captured output until done.
export "mc_ctl_exec_start" group="exec" { arg "cmd_len" type="u32"; ret "i32"; doc "Start a job from the cmd bytes in the scratch buffer; a job id, or negative errno." }
export "mc_ctl_exec_poll"  group="exec" { arg "job_id" type="u32"; ret "i32"; doc "Drain a job's output to the scratch buffer; >=0 bytes, a done marker, or negative errno." }
export "mc_ctl_exec_peek"  group="exec" { arg "job_id" type="u32"; ret "i32"; doc "Copy output captured so far without consuming it." }
export "mc_ctl_exec_close" group="exec" { arg "job_id" type="u32"; ret "i32"; doc "Release a finished job." }

// ── host-driven resident-service calls ───────────────────────────────────────
// Trusted operator calls into a resident service. The service receives caller=SYSTEM_CALLER.
export "mc_ctl_svc_call_start" group="service" { arg "name_ptr" type="u32"; arg "name_len" type="u32"; arg "req_ptr" type="u32"; arg "req_len" type="u32"; ret "i32"; doc "Start a host-control service call using name and request bytes from the scratch buffer; a job id, or negative errno." }
export "mc_ctl_svc_call_poll"  group="service" { arg "job_id" type="u32"; ret "i32"; doc "Poll a host-control service call. 0 running, 1 done with [status:i32][body_len:u32][body] in the scratch buffer, or negative errno." }
export "mc_ctl_svc_call_close" group="service" { arg "job_id" type="u32"; ret "i32"; doc "Release a host-control service call job." }

// ── layers / snapshots / quiescence (A8) ─────────────────────────────────────
export "mc_commit_layer"     group="snapshot" { ret "i32"; doc "Commit the current writable layer into a content-addressed image layer." }
export "mc_inflight_egress"  group="snapshot" { ret "i32"; doc "Count of in-flight egress operations (a snapshot must wait for 0)." }
export "mc_pending_commits"  group="snapshot" { ret "i32"; doc "Count of pending layer commits." }
// Quiescence is only meaningful with worker threads (a coop kernel is already quiescent
// between ticks), so these exist only in the threads build — cfg-gated, but still part of
// the canonical control surface the contract describes.
export "mc_quiesce_request"  group="snapshot" cfg="threads" { ret "i32"; doc "Ask the kernel to reach a quiescent point safe to snapshot/fork." }
export "mc_quiesce_release"  group="snapshot" cfg="threads" { ret "i32"; doc "Resume from a quiesced state." }

// ── threading worker entry (real-OS-thread build) ────────────────────────────
export "mc_worker_entry" group="threading" cfg="threads" { arg "arg" type="i32"; ret "i32"; doc "Entry point a host worker thread calls to join the kernel scheduler." }
