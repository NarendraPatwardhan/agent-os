# @mc/core — the unified Vm API over the embedded @mc/host backend, browser artifacts, and the
# remote REST + typed WebSocket contract. Published under the @mc/* scope.
load("//bazel:ts.bzl", "mc_ts_project")
load("@aspect_rules_js//js:defs.bzl", "js_binary", "js_run_binary", "js_test")
load("@aspect_rules_js//npm:defs.bzl", "npm_package")
load("@npm//:defs.bzl", "npm_link_all_packages")

# Link @mc/core's deps (@mc/host, @mc/contracts, zod) into :node_modules/*.
npm_link_all_packages(name = "node_modules")

# Role-named (:lib), not :core — the package directory already namespaces it; the target names the role.
mc_ts_project(
    name = "lib",
    srcs = glob(["src/**/*.ts"]),
    deps = [
        ":node_modules/@mc/host",  # the embedded backend drives the in-process kernel host
        ":node_modules/@mc/contracts",  # the contract SsoT: tier ordinals + mount-op/dirent/errno constants
        ":node_modules/zod",  # typed-tool input validation
        "//:node_modules/@types/bun",  # process + node:fs (artifacts/store loaders)
    ],
    visibility = ["//visibility:public"],
)

# @mc/core as a linkable workspace package. Keep this parallel to @mc/host and @mc/contracts so
# downstream @mc/* packages depend on the package boundary, not deep source labels.
npm_package(
    name = "pkg",
    srcs = [
        ":lib",
        "package.json",
    ],
    package = "@mc/core",
    visibility = ["//visibility:public"],
)

# Bundle @mc/core into a SINGLE self-contained ESM with rolldown (the repo's bundler, same engine
# as //memcontainers/sdk-js/elements:bundle), inlining @mc/host, @mc/contracts, and zod. A consumer
# imports this ONE file — no npm install, no node_modules. This is the release "js bundle" asset
# uploaded by //bazel/tools/gh-release. Node builtins stay external (Bun/Node provide them).
js_binary(
    name = "bundle_bin",
    chdir = package_name(),
    data = [":node_modules/rolldown"],
    entry_point = "tools/bundle.mjs",
)

js_run_binary(
    name = "bundle",
    srcs = [
        ":lib",
        ":node_modules/@mc/host",
        ":node_modules/@mc/contracts",
        ":node_modules/zod",
        ":node_modules/rolldown",
    ],
    outs = ["mc-core.mjs"],
    args = [
        "src/index.js",
        "mc-core.mjs",
    ],
    chdir = package_name(),
    tool = ":bundle_bin",
    visibility = ["//visibility:public"],
)

genrule(
    name = "github_issues_fixture",
    srcs = ["//memcontainers/lib/catalog-compiler:data/github_issues.openapi.json"],
    outs = ["data/github_issues.openapi.json"],
    cmd = "cp $< $@",
)

# Shared cross-host discovery-parity fixture (P3): the SAME introspection the Rust host's tool_plane
# discovery test serves, so both hosts compile it through catalog-compiler.wasm to the identical catalog.
genrule(
    name = "graphql_introspection_fixture",
    srcs = ["//memcontainers/lib/catalog-compiler:data/graphql.introspection.json"],
    outs = ["data/graphql.introspection.json"],
    cmd = "cp $< $@",
)

# Core-level runtime test: a real mc.create() boots the kernel through @mc/host and @mc/contracts package
# deps (the host parity test only covers @mc/host itself). Same load-bearing data edge as the Rust e2e:
# the kernel + image it boots are the ones its sources produce.
mc_ts_project(
    name = "vm_test_lib",
    srcs = ["test/vm.test.ts"],
    deps = [
        ":lib",
        ":node_modules/@mc/contracts",
        "//:node_modules/@types/bun",
    ],
)

js_test(
    name = "vm_test",
    data = [
        ":vm_test_lib",
        ":github_issues_fixture",
        ":graphql_introspection_fixture",
        "//memcontainers/kernel/rust:kernel",
        "//memcontainers/images:atlas",
        "//memcontainers/images:base",
        "//memcontainers/images:loom",
        "//memcontainers/lib/catalog-compiler:wasm",
    ],
    entry_point = "test/vm.test.js",
    env = {
        "MC_KERNEL_WASM": "$(rlocationpath //memcontainers/kernel/rust:kernel)",
        "MC_ATLAS_IMAGE": "$(rlocationpath //memcontainers/images:atlas)",
        "MC_BASE_IMAGE": "$(rlocationpath //memcontainers/images:base)",
        "MC_LOOM_IMAGE": "$(rlocationpath //memcontainers/images:loom)",
        "MC_CATALOG_COMPILER_WASM": "$(rlocationpath //memcontainers/lib/catalog-compiler:wasm)",
        "MC_GITHUB_FIXTURE": "$(rlocationpath :github_issues_fixture)",
        "MC_GRAPHQL_FIXTURE": "$(rlocationpath :graphql_introspection_fixture)",
    },
)

# Design-doc browser build gate: solve the same canonical LLB Definition in
# headless Chromium using OPFS and compare the root digest to the local solve.
mc_ts_project(
    name = "browser_opfs_test_lib",
    srcs = ["test/browser_opfs.test.ts"],
    deps = [
        ":lib",
        "//:node_modules/@types/bun",
    ],
)

js_test(
    name = "browser_opfs_test",
    data = [
        ":browser_opfs_test_lib",
        "//memcontainers/images:base",
        "//memcontainers/kernel/rust:kernel",
    ],
    entry_point = "test/browser_opfs.test.js",
    env = {
        "MC_KERNEL_WASM": "$(rlocationpath //memcontainers/kernel/rust:kernel)",
        "MC_BASE_IMAGE": "$(rlocationpath //memcontainers/images:base)",
    },
)
