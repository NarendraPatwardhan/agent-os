load("@rules_zig//zig:defs.bzl", "zig_library")

# sysroot/zig — the ZIG lane of the guest sysroot (sibling of //memcontainers/sysroot/rust): the shared
# `mc` syscall ABI that luau, sqlite (and a future Zig shell over shcore) `@import("mc")`. The callable
# `extern "mc" fn` block is GENERATED from contracts/syscalls.kdl (//memcontainers/contracts:mc_zig) and
# re-exported by mc.zig, so it cannot drift from the kernel's served surface — the abi_library diff gate
# is the single source of truth (the old hand-kept decls + //bazel/tools/mc-abi-gate are gone). svc.zig
# adds the resident-service serve-loop scaffolding (over the svc_* server syscalls) for a one-binary,
# two-modes service.

zig_library(
    name = "mc",
    # The `mc` module IS the generated projection (contracts/gen/mc.gen.zig): every syscall extern
    # + the addr helper, nothing hand-kept. import_name defaults to the target name "mc", so a guest
    # `@import("mc")` gets it directly. The descriptor tables in the same file (used by the kernel)
    # are unreferenced here and dropped by the linker.
    main = "//memcontainers/contracts:gen/mc.gen.zig",
    visibility = ["//visibility:public"],
)

# The resident-service serve-loop scaffolding (serve / recv-envelope / respond) over the svc_* server
# syscalls. A Zig service `@import("svc")` and writes only its dispatch (sqlite today).
zig_library(
    name = "svc",
    main = "svc.zig",
    deps = [
        ":mc",
        "//memcontainers/contracts:constants_zig",  # the projected SERVICE_MARKER (codex #5), re-exported by svc.zig
    ],
    visibility = ["//visibility:public"],
)
