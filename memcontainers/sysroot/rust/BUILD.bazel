load("@rules_rust//rust:defs.bzl", "rust_library")
load("//bazel:wasm32_build_test.bzl", "wasm32_build_test")

# sysroot/rust — the RUST lane of the agent-os guest sysroot (SYSTEMS.md; sibling of //memcontainers/sysroot/zig):
# the safe `mc` syscall surface every Rust wasm guest links. The `mc` import block is GENERATED from
# contracts/syscalls.kdl — a guest `$emit` on the SAME `mc_syscall_table!` the kernel's
# dispatch derives from (B2: a guest can't import a syscall the kernel doesn't serve, drift
# = compile error). The ergonomic safe wrappers + the `entry!`/`declare_tier!`/
# `declare_budget!` macros are PORTED over that generated boundary (generate the boundary,
# port the comfort). Compiles to wasm32-unknown-unknown; consumed by //memcontainers/programs.

rust_library(
    name = "rust",
    crate_name = "sysroot",  # the crate stays `sysroot` (guests `use sysroot as rt`); only the label moved
    srcs = glob(["src/**/*.rs"]),
    edition = "2021",
    # A wasm32-only no_std rlib: the `#[link(wasm_import_module = "mc")]` extern block and
    # the no_std panic handler have no native build, so `//...` does not build it directly —
    # it is compiled under //memcontainers/programs' guests, and under the wasm32 build_test below.
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [
        "//memcontainers/contracts:mc_rust",         # mc_syscall_table! → the generated `mc` import block (B2)
        "//memcontainers/contracts:constants_rust",  # errno / O_* / TIER_* / SEEK_* / SIG* / CAP_* (B2)
    ],
)

# Assert the sysroot compiles for its real target, wasm32.
wasm32_build_test(
    name = "test",
    lib = ":rust",
)
