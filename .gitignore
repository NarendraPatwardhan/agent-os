# Bazel outputs — every artifact is a pure function of its declared inputs (B1),
# so nothing under bazel-* is ever committed; `bazel test //...` regenerates it.
/bazel-*

# Local toolchain caches (zig translate-c, direct `zig build` experiments).
.zig-cache/
zig-out/

# npm/pnpm — node_modules is a regenerable LOCAL-DEV artifact (for the editor + lockfile generation).
# Bazel never uses it: rules_js links its OWN hermetic node_modules under bazel-* from pnpm-lock.yaml.
# The lockfile, the package.json manifests, pnpm-workspace.yaml, and tsconfig.json ARE committed.
node_modules/
*.tsbuildinfo

# Editor / OS noise
*.swp
*~
.DS_Store

# NB: MODULE.bazel.lock IS committed (hermetic, reproducible resolution — B4).
