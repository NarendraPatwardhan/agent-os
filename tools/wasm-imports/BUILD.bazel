load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")

# tools/wasm-imports — the wasm import-section oracle, the ONE primitive behind conformance
# (VISION §9.3) and capability attestation (§16.4). Both gates walk a guest's wasm imports
# and check the function symbols it pulls from a module (`mc`, `env`) against an allowed set;
# they differ only in the set (declared syscall table vs. a tier's syscalls), so the walk
# lives here once. A NATIVE std library + CLI (it inspects guest wasm; it is not itself a
# guest). The import reader is `wasmparser`, surfaced as a top-level `@host_crates//:` alias
# by a direct dep in //hosts/wasmtime:Cargo.toml (it was already pinned there transitively
# via wasmtime 43).

# The core library: `imported_function_symbols` + the typed `ImportedSymbols` set. This is
# what //conformance and the attest rules call; keep it clean — the set comparison
# (⊆ a table, ⊆ a tier, coverage union) is the caller's, the walk is ours.
rust_library(
    name = "lib",
    srcs = ["src/lib.rs"],
    crate_name = "wasm_imports",
    edition = "2021",
    visibility = ["//visibility:public"],
    deps = [
        "@host_crates//:anyhow",
        "@host_crates//:wasmparser",
    ],
)

# The CLI: `wasm-imports <wasm> <module>` prints the sorted imported symbols one per line,
# with optional `--require`/`--allowed-file` check modes a Bazel test/genrule can drive.
rust_binary(
    name = "cli",
    srcs = ["src/main.rs"],
    edition = "2021",
    visibility = ["//visibility:public"],
    deps = [
        ":lib",
        "@host_crates//:anyhow",
        "@host_crates//:clap",
    ],
)

# Proof on a REAL artifact (B6, §7.2) that doubles as the §9.3 conformance check: walk the
# genuine //kernel/rust:kernel wasm and assert its `env` imports ⊆ the DECLARED bridge —
# //contracts:env_rust's BRIDGE_IMPORTS, the projection, never a hand-listed copy of the
# surface (that copy was the bug). The kernel is a `data` dep, located via the runfiles crate
# as //tests/e2e does.
rust_test(
    name = "kernel_imports",
    srcs = ["tests/kernel_imports.rs"],
    edition = "2021",
    data = ["//kernel/rust:kernel"],
    deps = [
        ":lib",
        "//contracts:env_rust",
        "@rules_rust//rust/runfiles",
    ],
)

# Unit tests live INSIDE src/lib.rs (#[cfg(test)] over hand-rolled wasm fixtures); this
# target runs them without a kernel dep, so the primitive's logic is covered fast.
rust_test(
    name = "lib_test",
    crate = ":lib",
    edition = "2021",
)
