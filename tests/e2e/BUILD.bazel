load(":defs.bzl", "rust_e2e_test")

# tests/e2e — the no-mocks end-to-end suite. Each test boots the REAL kernel.wasm in the
# REAL wasmtime host with capture sinks and .deterministic() (fixed clock + seeded rng), and
# asserts on REAL stdout bytes / REAL control-channel reads (VISION §9.1, B6). Booting is
# itself a test — a kernel trap or a generated-bridge mismatch surfaces as a host error.
#
# THE load-bearing edge (B1, §7.2): the test `data`-depends on the kernel + image targets,
# so the artifacts a test runs are ALWAYS the ones its sources produce — the death of the
# memcontainers staleness class. In Phase B this edge fans out to BOTH kernels (§9.6).
#
# Always RELEASE wasmtime: rust_e2e_test pins the host subgraph to compilation_mode=opt
# (defs.bzl), so a debug wasmtime never makes the suite crawl.

rust_e2e_test(
    name = "e2e",
    srcs = glob(["src/**/*.rs"]),
    edition = "2021",
    deps = [
        "//hosts/wasmtime:host",
        "@rules_rust//rust/runfiles",
    ],
    # kernel defaults to //kernel/rust:kernel (the macro adds it as a data-dep and passes its
    # runfiles path via MC_KERNEL_WASM). The Zig kernel gets its own target — same srcs,
    # kernel = //kernel/zig:kernel — under the B7 parity gate (§9.6).
    data = [
        "//images:base",
        "//images:posix",  # base + guest /bin/sh + the coreutils box (the coreutils tests)
    ],
)
