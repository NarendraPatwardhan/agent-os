# tests/e2e — the no-mocks end-to-end suite (ported from memcontainers crates/e2e).
# Each test boots the real kernel.wasm in hosts/wasmtime with capture sinks and
# .deterministic() (fixed clock + seeded rng), runs commands, and asserts on REAL
# stdout/stderr bytes and REAL exit codes; network tests hit the REAL internet (VISION
# §9.1, B6). Booting is itself a test — a kernel trap surfaces as a host error.
#
# THE load-bearing edge (B1, §7.2): the test `data`-depends on the kernel target, so the
# kernel a test runs is ALWAYS the one its sources produce. This is the death of the
# memcontainers staleness class. In Phase B this edge fans out to BOTH kernels (§9.6).
#
# Phase A:
#   load("@rules_rust//rust:defs.bzl", "rust_test")
#   rust_test(
#       name = "e2e",
#       srcs = glob(["src/**/*.rs"]),       # boot, pipes, net, persist, control, snapshot, services, sqlite, luau
#       deps = ["//hosts/wasmtime:host"],
#       data = ["//kernel/rust:kernel", "//images:base_tar"],   # never stale (B1)
#   )
