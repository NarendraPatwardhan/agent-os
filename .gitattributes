# Unified diffs require a leading context marker even on blank source lines.
third_party/tree-sitter/patches/*.patch whitespace=-blank-at-eol

# Format only first-party, handwritten sources. Generated projections are formatted by their
# generator and checked by drift tests; upstream sources retain upstream formatting.
third_party/** rules-lint-ignored
memcontainers/contracts/gen/** linguist-generated=true
memcontainers/programs/syntax/grammars/gen/** linguist-generated=true
server/lib/agent_os/contracts/*.ex linguist-generated=true
