load("@aspect_bazel_lib//lib:transitions.bzl", "platform_transition_filegroup")
load("@bazel_skylib//rules:build_test.bzl", "build_test")
load("@rules_rust//rust:defs.bzl", "rust_shared_library")

# Bootstrap Rust→wasm smoke — proves rules_rust compiles a no_std cdylib to
# wasm32-unknown-unknown, the exact shape kernel/rust takes (Step 2 spine). The Rust
# counterpart of //bazel/tools/smoke/zig. Remove once kernel/rust provides a real wasm
# target to anchor the spine.

# The cdylib. Tagged manual: it is only meaningful under the wasm transition below
# (a host-default build of a no_std cdylib has no runtime), so `//...` must not take it.
rust_shared_library(
    name = "lib",
    srcs = ["lib.rs"],
    edition = "2021",
    tags = ["manual"],
)

# Transition the cdylib to wasm32-unknown-unknown so it builds under `bazel test //...`
# with no command-line flag — the Rust counterpart of zig_configure_binary.
platform_transition_filegroup(
    name = "wasm",
    srcs = [":lib"],
    target_platform = "//platforms:wasm32_freestanding",
)

# Anchors the Rust→wasm spine in the test graph: asserts the wasm artifact builds.
build_test(
    name = "test",
    targets = [":wasm"],
)
