load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_test")

# mc-attest — the §16.4 capability attestation tool. Reads a box's declared tier (mc_tier section)
# + its mc imports and fails if any import's cap-floor (SYSCALL_CAPS) does not intersect
# tier_caps(tier). A host binary; both matrices come straight from the projected contract (B2),
# so there are no hardcoded caps. //bazel:mc_box.bzl `mc_box` runs it as a per-box build gate.
rust_binary(
    name = "mc-attest",
    srcs = ["src/main.rs"],
    edition = "2021",
    deps = [
        "//memcontainers/contracts:mc_rust",  # SYSCALL_CAPS (syscall → cap-floor names)
        "//memcontainers/contracts:constants_rust",  # tier_caps + CAP_*/TIER_* bits
    ],
    visibility = ["//visibility:public"],
)

# The gate's logic, unit-tested directly (it's pure): minimal crafted boxes prove it ACCEPTS
# tier-fitting imports and REJECTS over-reach (spawn/net at read-only, ambient at isolated).
rust_test(
    name = "test",
    crate = ":mc-attest",
    edition = "2021",
    size = "small",
)
